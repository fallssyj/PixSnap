<!-- 编码：UTF-8 BOM -->
<!-- 窗口截图选择器：鼠标悬停于目标窗口时自动高亮边框，单击捕获 -->
<Window x:Class="PixSnap.View.WindowSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="窗口截图"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        WindowStartupLocation="Manual">

    <Grid>
        <!-- 半透明遮罩层，略微降低背景亮度以突出高亮框 -->
        <Rectangle Fill="#1A000000" IsHitTestVisible="False"/>

        <!-- Canvas：高亮框 + 标题标签（不参与命中测试，不阻挡鼠标事件） -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">

            <!-- 目标窗口高亮边框 -->
            <Border x:Name="HighlightBorder"
                    BorderThickness="3"
                    BorderBrush="#FF4FC3F7"
                    Background="#1A4FC3F7"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect Color="#4FC3F7" BlurRadius="16"
                                      ShadowDepth="0" Opacity="0.85"/>
                </Border.Effect>
            </Border>

            <!-- 窗口标题标签（贴在高亮框顶部上方） -->
            <Border x:Name="TitleLabel"
                    Background="#E6101A2E"
                    CornerRadius="4"
                    Padding="10,4"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbWindowTitle"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </Border>
        </Canvas>

        <!-- 底部操作提示 -->
        <StackPanel VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,48">
            <Border Background="#E6101A2E"
                    CornerRadius="8"
                    Padding="22,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="单击" Foreground="#FF4FC3F7"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text=" 捕获窗口    "
                               Foreground="White" FontSize="13"/>
                    <TextBlock Text="右键 / Esc" Foreground="#FF4FC3F7"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text=" 取消"
                               Foreground="White" FontSize="13"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
