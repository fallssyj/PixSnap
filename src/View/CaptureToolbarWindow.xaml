<!-- 截图工具栏窗口：浮动工具栏，提供截图模式选择和启动按钮 -->
<Window x:Class="PixSnap.View.CaptureToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:PixSnap.ViewModels"
        Title="PixSnap 截图"
        Height="56" Width="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- 工具栏主容器 -->
    <Border Background="{StaticResource BackgroundMediumBrush}"
            CornerRadius="10"
            BorderBrush="{StaticResource BorderNormalBrush}"
            BorderThickness="1">

        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.6" ShadowDepth="4" Direction="270" Color="Black"/>
        </Border.Effect>

        <Grid Margin="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- LOGO 文字 -->
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <!-- 模式下拉 -->
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <!-- 开始按钮 -->
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <!-- 关闭按钮 -->
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <TextBlock Grid.Column="0"
                       Text="PixSnap"
                       Foreground="{StaticResource AccentBrush}"
                       FontWeight="Bold"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="4,0"/>

            <!-- 截图模式下拉 -->
            <ComboBox Grid.Column="2"
                      x:Name="ComboMode"
                      ItemsSource="{Binding CaptureModes}"
                      SelectedItem="{Binding SelectedCaptureMode}"
                      DisplayMemberPath="DisplayName"
                      VerticalAlignment="Center"/>

            <!-- 开始截图按钮 -->
            <Button Grid.Column="4"
                    Command="{Binding StartCaptureCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    Width="80" Height="36"
                    Background="{StaticResource AccentBrush}"
                    ToolTip="开始截图">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- 截图图标 -->
                    <Path Width="16" Height="16" Margin="0,0,4,0"
                          Fill="{StaticResource TextPrimaryBrush}"
                          Data="M4,1 L3,0 L0,0 L0,3 L1,4 L1,1 Z M12,1 L13,0 L16,0 L16,3 L15,4 L15,1 Z M4,15 L3,16 L0,16 L0,13 L1,12 L1,15 Z M12,15 L13,16 L16,16 L16,13 L15,12 L15,15 Z M5,5 L11,5 L11,11 L5,11 Z"/>
                    <TextBlock Text="截图"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 关闭按钮 -->
            <Button Grid.Column="6"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTip="取消 (Esc)">
                <Path Width="10" Height="10"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="2"
                      StrokeLineJoin="Round"
                      Data="M0,0 L10,10 M10,0 L0,10"/>
            </Button>
        </Grid>
    </Border>
</Window>
