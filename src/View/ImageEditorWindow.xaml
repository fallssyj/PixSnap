<!-- 编码：UTF-8 BOM -->
<!-- 图片编辑器主窗口：包含工具栏、画板和调色板 -->
<hc:Window x:Class="PixSnap.View.ImageEditorWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:vm="clr-namespace:PixSnap.ViewModels"
           xmlns:models="clr-namespace:PixSnap.Models"
           Title="PixSnap 图片处理"
           Width="1000" Height="700"
           MinWidth="720" MinHeight="500"
           WindowStartupLocation="CenterScreen"
           Background="{StaticResource BackgroundDarkBrush}"
           NonClientAreaBackground="{StaticResource BackgroundDarkBrush}"
           ShowInTaskbar="True">

    <hc:Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- DrawToolType 到 bool 的转换不在此处，使用命令绑定 -->
        </ResourceDictionary>
    </hc:Window.Resources>

    <!-- 快捷键绑定 -->
    <hc:Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyToClipboardCommand}"/>
        <KeyBinding Key="Add" Modifiers="Ctrl" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="Subtract" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ZoomResetCommand}"/>
    </hc:Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 菜单/顶部工具栏 -->
            <RowDefinition Height="*"/>
            <!-- 主要内容区 -->
            <RowDefinition Height="28"/>
            <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ===== 顶部工具栏 ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderNormalBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">

                <!-- 撤销 -->
                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding UndoCommand}"
                        IsEnabled="{Binding CanUndo}"
                        ToolTip="撤销 (Ctrl+Z)">
                    <Path Width="16" Height="16"
                          Fill="{StaticResource TextPrimaryBrush}"
                          Data="M4,8 C4,5.8 5.8,4 8,4 C10.2,4 12,5.8 12,8 C12,10.2 10.2,12 8,12 L8,14 L4,10 L8,6 L8,8 C9.1,8 10,8.9 10,10 C10,11.1 9.1,12 8,12 C6.9,12 6,11.1 6,10 L4,10 Z"/>
                </Button>

                <!-- 重做 -->
                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding RedoCommand}"
                        IsEnabled="{Binding CanRedo}"
                        ToolTip="重做 (Ctrl+Y)">
                    <Path Width="16" Height="16"
                          Fill="{StaticResource TextPrimaryBrush}"
                          Data="M12,8 C12,5.8 10.2,4 8,4 C5.8,4 4,5.8 4,8 C4,10.2 5.8,12 8,12 L8,14 L12,10 L8,6 L8,8 C6.9,8 6,8.9 6,10 C6,11.1 6.9,12 8,12 C9.1,12 10,11.1 10,10 L12,10 Z"/>
                </Button>

                <Separator Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- 缩放控件 -->
                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding ZoomOutCommand}"
                        ToolTip="缩小 (Ctrl+-)">
                    <Path Width="14" Height="14"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="2"
                          Data="M2,7 L12,7"/>
                </Button>

                <TextBlock Text="{Binding ZoomText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           MinWidth="48"
                           TextAlignment="Center"
                           Margin="4,0"/>

                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding ZoomInCommand}"
                        ToolTip="放大 (Ctrl++)">
                    <Path Width="14" Height="14"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="2"
                          Data="M2,7 L12,7 M7,2 L7,12"/>
                </Button>

                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding ZoomResetCommand}"
                        ToolTip="重置缩放 (Ctrl+0)">
                    <TextBlock Text="1:1"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Button>

                <Separator Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- 裁剪 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="内缩裁剪："
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <hc:NumericUpDown Value="{Binding InsetValue}"
                                     Minimum="0" Maximum="200"
                                     Width="70" Height="28"
                                     FontSize="12"
                                     Margin="4,0"
                                     ToolTip="上下左右各内缩像素数"/>
                    <Button Style="{StaticResource ToolPanelButtonStyle}"
                            Command="{Binding ApplyInsetCropCommand}"
                            ToolTip="应用裁剪">
                        <Path Width="14" Height="14"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.5"
                              Data="M0,4 L4,4 L4,0 M0,10 L4,10 L4,14 M14,0 L10,0 L10,4 M14,14 L10,14 L10,10 M4,4 L10,10 M4,10 L10,4"/>
                    </Button>
                </StackPanel>

                <Separator Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- 圆角 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="圆角："
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <hc:NumericUpDown Value="{Binding CornerRadius}"
                                     Minimum="0" Maximum="200"
                                     Width="70" Height="28"
                                     FontSize="12"
                                     Margin="4,0"
                                     ToolTip="圆角半径（像素）"/>
                    <Button Style="{StaticResource ToolPanelButtonStyle}"
                            Command="{Binding ApplyRoundCornersCommand}"
                            ToolTip="应用圆角">
                        <Path Width="14" Height="14"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M4,0 L10,0 C12.2,0 14,1.8 14,4 L14,10 C14,12.2 12.2,14 10,14 L4,14 C1.8,14 0,12.2 0,10 L0,4 C0,1.8 1.8,0 4,0 Z"/>
                    </Button>
                </StackPanel>

                <Separator Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- 保存/复制 -->
                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding CopyToClipboardCommand}"
                        ToolTip="复制到剪贴板 (Ctrl+C)">
                    <Path Width="16" Height="16"
                          Fill="{StaticResource TextPrimaryBrush}"
                          Data="M11,2 L9,2 C9,0.9 8.1,0 7,0 C5.9,0 5,0.9 5,2 L3,2 C1.9,2 1,2.9 1,4 L1,14 C1,15.1 1.9,16 3,16 L11,16 C12.1,16 13,15.1 13,14 L13,4 C13,2.9 12.1,2 11,2 Z M7,2 C7.6,2 8,2.4 8,3 C8,3.6 7.6,4 7,4 C6.4,4 6,3.6 6,3 C6,2.4 6.4,2 7,2 Z M11,14 L3,14 L3,4 L5,4 L5,6 L9,6 L9,4 L11,4 Z"/>
                </Button>

                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding SaveCommand}"
                        ToolTip="快速保存到桌面 (Ctrl+S)">
                    <Path Width="16" Height="16"
                          Fill="{StaticResource TextPrimaryBrush}"
                          Data="M13,0 L2,0 C0.9,0 0,0.9 0,2 L0,14 C0,15.1 0.9,16 2,16 L14,16 C15.1,16 16,15.1 16,14 L16,3 Z M8,14 C6.3,14 5,12.7 5,11 C5,9.3 6.3,8 8,8 C9.7,8 11,9.3 11,11 C11,12.7 9.7,14 8,14 Z M11,5 L2,5 L2,2 L11,2 Z"/>
                </Button>

                <Button Style="{StaticResource ToolPanelButtonStyle}"
                        Command="{Binding SaveAsCommand}"
                        ToolTip="另存为 (Ctrl+Shift+S)">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="14" Height="14"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Data="M13,0 L2,0 C0.9,0 0,0.9 0,2 L0,14 C0,15.1 0.9,16 2,16 L14,16 C15.1,16 16,15.1 16,14 L16,3 Z M8,14 C6.3,14 5,12.7 5,11 C5,9.3 6.3,8 8,8 C9.7,8 11,9.3 11,11 C11,12.7 9.7,14 8,14 Z M11,5 L2,5 L2,2 L11,2 Z"/>
                        <TextBlock Text="…" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <!-- 左侧工具栏 -->
                <ColumnDefinition Width="*"/>
                <!-- 画板/预览区 -->
                <ColumnDefinition Width="160"/>
                <!-- 右侧属性面板 -->
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧绘图工具栏 ===== -->
            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderNormalBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top" Margin="6,8">

                    <!-- 选择工具 -->
                    <Button x:Name="BtnSelect"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Select"
                            Click="ToolButton_Click"
                            ToolTip="选择 (V)">
                        <Path Width="16" Height="16"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Data="M0,0 L0,14 L5,9 L8,14 L10,13 L7,8 L13,8 Z"/>
                    </Button>

                    <Separator Style="{StaticResource ToolbarSeparatorStyle}" Margin="4,4" Height="1" Width="Auto"/>

                    <!-- 画笔 -->
                    <Button x:Name="BtnPen"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Pen"
                            Click="ToolButton_Click"
                            ToolTip="画笔 (B)">
                        <Path Width="16" Height="16"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Data="M0,14 L1,10 L10,1 C10.8,0.2 12,0.2 12.8,1 L13,1.2 C13.8,2 13.8,3.2 13,4 L4,13 Z M3,11 L1,13 L3,13 Z"/>
                    </Button>

                    <!-- 直线 -->
                    <Button x:Name="BtnLine"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Line"
                            Click="ToolButton_Click"
                            ToolTip="直线 (L)">
                        <Path Width="16" Height="16"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              Data="M1,13 L13,1"/>
                    </Button>

                    <!-- 矩形 -->
                    <Button x:Name="BtnRect"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Rectangle"
                            Click="ToolButton_Click"
                            ToolTip="矩形 (R)">
                        <Path Width="16" Height="16"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Data="M1,2 L15,2 L15,14 L1,14 Z"/>
                    </Button>

                    <!-- 椭圆 -->
                    <Button x:Name="BtnEllipse"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Ellipse"
                            Click="ToolButton_Click"
                            ToolTip="椭圆 (E)">
                        <Path Width="16" Height="16"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Data="M8,1 C12,1 15,4 15,8 C15,12 12,15 8,15 C4,15 1,12 1,8 C1,4 4,1 8,1 Z"/>
                    </Button>

                    <!-- 箭头 -->
                    <Button x:Name="BtnArrow"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Arrow"
                            Click="ToolButton_Click"
                            ToolTip="箭头 (A)">
                        <Path Width="16" Height="16"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Data="M1,13 L10,4 L7,4 L7,1 L15,1 L15,9 L12,9 L12,6 L3,15 Z"/>
                    </Button>

                    <!-- 文字 -->
                    <Button x:Name="BtnText"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Text"
                            Click="ToolButton_Click"
                            ToolTip="文字标注 (T)">
                        <Path Width="16" Height="16"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Data="M0,2 L0,0 L16,0 L16,2 L9,2 L9,16 L7,16 L7,2 Z"/>
                    </Button>

                    <Separator Style="{StaticResource ToolbarSeparatorStyle}" Margin="4,4" Height="1" Width="Auto"/>

                    <!-- 橡皮擦 -->
                    <Button x:Name="BtnEraser"
                            Style="{StaticResource ToolPanelButtonStyle}"
                            Tag="Eraser"
                            Click="ToolButton_Click"
                            ToolTip="橡皮擦 (X)">
                        <Path Width="16" Height="16"
                              Fill="{StaticResource TextPrimaryBrush}"
                              Data="M1,13 L7,7 L11,11 L5,16 Z M8,6 L14,12 L16,10 L10,4 Z M12,3 L13,2 C13.8,1.2 15,1.2 15.8,2 C16.6,2.8 16.6,4 15.8,4.8 L14.8,5.8 Z M0,16 L6,16 L5,15 L1,15 Z"/>
                    </Button>

                </StackPanel>
            </Border>

            <!-- ===== 画板区域（带滚动和缩放）===== -->
            <ScrollViewer Grid.Column="1"
                          x:Name="CanvasScrollViewer"
                          Background="{StaticResource BackgroundDarkBrush}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="CanvasScrollViewer_PreviewMouseWheel">

                <!-- 缩放容器 -->
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="24">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomScale}"
                                        ScaleY="{Binding ZoomScale}"/>
                    </Grid.LayoutTransform>

                    <!-- 阴影效果 -->
                    <Grid.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="8" Direction="270" Color="Black"/>
                    </Grid.Effect>

                    <!-- 图片容器 -->
                    <Grid x:Name="ImageContainer">
                        <!-- 底层：截图图片 -->
                        <Image x:Name="BaseImage"
                               Source="{Binding DisplayImage}"
                               Stretch="None"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                        <!-- 上层：绘制 Canvas（WPF 矢量叠加层，仅用于实时预览正在绘制的元素）-->
                        <Canvas x:Name="DrawingCanvas"
                                Background="Transparent"
                                Cursor="{Binding DrawCursor}"
                                MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                                MouseMove="DrawingCanvas_MouseMove"
                                MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp"
                                MouseRightButtonDown="DrawingCanvas_MouseRightButtonDown"/>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- ===== 右侧属性面板 ===== -->
            <Border Grid.Column="2"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderNormalBrush}"
                    BorderThickness="1,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,12">

                        <!-- 颜色标题 -->
                        <TextBlock Text="颜色"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>

                        <!-- 当前颜色预览 -->
                        <Border Width="140" Height="28"
                                BorderBrush="{StaticResource BorderNormalBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,0,8"
                                Cursor="Hand"
                                MouseLeftButtonDown="CurrentColorPreview_Click">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding StrokeColor}"/>
                            </Border.Background>
                        </Border>

                        <!-- 颜色调色板 -->
                        <ItemsControl ItemsSource="{Binding PaletteColors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Width="140"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ColorPickerButtonStyle}"
                                            Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Background>
                                            <SolidColorBrush Color="{Binding}"/>
                                        </Button.Background>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="{StaticResource BorderNormalBrush}" Margin="0,10"/>

                        <!-- 线条粗细 -->
                        <TextBlock Text="线条粗细"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>

                        <Slider Style="{StaticResource ToolSliderStyle}"
                                Minimum="1" Maximum="20"
                                Value="{Binding StrokeWidth}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Width="140"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0">
                            <TextBlock.Text>
                                <Binding Path="StrokeWidth" StringFormat="{}{0:F0} px"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <Separator Background="{StaticResource BorderNormalBrush}" Margin="0,10"/>

                        <!-- 字体大小（文字工具） -->
                        <TextBlock Text="字体大小"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>

                        <Slider Style="{StaticResource ToolSliderStyle}"
                                Minimum="8" Maximum="72"
                                Value="{Binding FontSize}"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Width="140"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0">
                            <TextBlock.Text>
                                <Binding Path="FontSize" StringFormat="{}{0:F0} pt"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <Separator Background="{StaticResource BorderNormalBrush}" Margin="0,10"/>

                        <!-- 填充开关 -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="填充形状"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <hc:ToggleBlock IsChecked="{Binding IsFilled}"
                                           Width="42" Height="22"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== 状态栏 ===== -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundDarkBrush}"
                BorderBrush="{StaticResource BorderNormalBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="TbCoordinate"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Text="坐标: -"/>
                    <TextBlock Foreground="{StaticResource BorderNormalBrush}"
                               Text="  |  " FontSize="11"/>
                    <TextBlock x:Name="TbImageSize"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Text="大小: -"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ZoomText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</hc:Window>
