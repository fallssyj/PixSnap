<!-- 快捷键录制对话框 -->
<hc:Window x:Class="PixSnap.HotkeyEditDialog"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="设置快捷键"
           Width="340" Height="200"
           WindowStartupLocation="CenterOwner"
           Background="{StaticResource BackgroundDarkBrush}"
           NonClientAreaBackground="{StaticResource BackgroundDarkBrush}"
           ResizeMode="NoResize">

    <hc:Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </hc:Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="按下要录制的组合键"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12"
                   HorizontalAlignment="Center"/>

        <!-- 快捷键显示框（接受按键输入）-->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="2"
                CornerRadius="8"
                Height="48">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=HotkeyCapture, Path=IsFocused}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <TextBox x:Name="HotkeyCapture"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource AccentBrush}"
                     FontSize="18"
                     FontWeight="Bold"
                     IsReadOnly="True"
                     TextAlignment="Center"
                     VerticalContentAlignment="Center"
                     Text="点击此处录制"
                     PreviewKeyDown="HotkeyCapture_PreviewKeyDown"
                     GotFocus="HotkeyCapture_GotFocus"/>
        </Border>

        <!-- 提示 -->
        <TextBlock Grid.Row="4"
                   x:Name="TbHint"
                   Text="请包含 Ctrl、Alt、Shift 中的至少一个修饰键"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"/>

        <!-- 确认/取消按钮 -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="BtnOk"
                    Content="确认"
                    Width="80" Height="32"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsEnabled="False"
                    Margin="0,0,10,0"
                    Click="BtnOk_Click"/>
            <Button Content="取消"
                    Width="80" Height="32"
                    Background="{StaticResource BackgroundMediumBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderNormalBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</hc:Window>
