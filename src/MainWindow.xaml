<!-- 编码：UTF-8 BOM -->
<!-- 主窗口：显示在托盘双击后弹出，包含快捷键设置等 -->
<hc:Window x:Class="PixSnap.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           Title="PixSnap 设置"
           Width="440" Height="380"
           WindowStartupLocation="CenterScreen"
           Background="{StaticResource BackgroundDarkBrush}"
           NonClientAreaBackground="{StaticResource BackgroundDarkBrush}"
           ShowInTaskbar="True">

    <hc:Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </hc:Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Logo 区 -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <!-- 快捷键设置 -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <!-- 保存目录 -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <!-- 状态 -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <!-- 底部按钮 -->
        </Grid.RowDefinitions>

        <!-- Logo 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <!-- PathGeometry 图标 -->
            <Viewbox Width="36" Height="36" Margin="0,0,12,0">
                <Canvas Width="36" Height="36">
                    <!-- 相机外框 -->
                    <Path Fill="{StaticResource AccentBrush}"
                          Data="M4,10 L8,10 L10,7 L26,7 L28,10 L32,10 C33.1,10 34,10.9 34,12 L34,28 C34,29.1 33.1,30 32,30 L4,30 C2.9,30 2,29.1 2,28 L2,12 C2,10.9 2.9,10 4,10 Z"/>
                    <!-- 镜头 -->
                    <Path Fill="{StaticResource BackgroundMediumBrush}"
                          Data="M18,25 C14.7,25 12,22.3 12,19 C12,15.7 14.7,13 18,13 C21.3,13 24,15.7 24,19 C24,22.3 21.3,25 18,25 Z"/>
                    <!-- 镜头高光 -->
                    <Path Fill="{StaticResource AccentHoverBrush}"
                          Data="M18,24 C15.2,24 13,21.8 13,19 C13,16.2 15.2,14 18,14 C20.8,14 23,16.2 23,19 C23,21.8 20.8,24 18,24 Z"/>
                    <!-- 闪光灯 -->
                    <Ellipse Canvas.Left="6" Canvas.Top="12" Width="5" Height="5"
                             Fill="{StaticResource TextSecondaryBrush}"/>
                </Canvas>
            </Viewbox>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="PixSnap"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="22"
                           FontWeight="Bold"/>
                <TextBlock Text="截图工具  v1.0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- 快捷键设置 -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundMediumBrush}"
                CornerRadius="8"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="全局快捷键"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="呼出截图快捷键："
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <!-- 快捷键显示 -->
                <Border Grid.Row="2" Grid.Column="1"
                        Background="{StaticResource BackgroundDarkBrush}"
                        BorderBrush="{StaticResource BorderNormalBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,6"
                        MinWidth="120">
                    <TextBlock x:Name="TbHotkey"
                               Text="Ctrl+Shift+A"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                </Border>

                <Button Grid.Row="2" Grid.Column="3"
                        x:Name="BtnChangeHotkey"
                        Content="修改"
                        Width="60" Height="30"
                        Background="{StaticResource BackgroundLightBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        Click="BtnChangeHotkey_Click"/>
            </Grid>
        </Border>

        <!-- 保存目录 -->
        <Border Grid.Row="4"
                Background="{StaticResource BackgroundMediumBrush}"
                CornerRadius="8"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="默认保存目录："
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         x:Name="TbSaveDir"
                         Background="{StaticResource BackgroundDarkBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderNormalBrush}"
                         BorderThickness="1"
                         FontSize="12"
                         Height="30"
                         Padding="8,4"
                         Text=""
                         VerticalContentAlignment="Center"/>

                <Button Grid.Column="3"
                        Content="浏览"
                        Width="50" Height="30"
                        Background="{StaticResource BackgroundLightBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        Click="BtnBrowse_Click"/>
            </Grid>
        </Border>

        <!-- 状态提示 -->
        <TextBlock Grid.Row="6"
                   x:Name="TbStatus"
                   Foreground="{StaticResource SuccessBrush}"
                   FontSize="12"
                   Text=""
                   TextWrapping="Wrap"/>

        <!-- 底部按钮区 -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <!-- 立即截图按钮 -->
            <Button x:Name="BtnCapture"
                    Click="BtnCapture_Click"
                    Width="110" Height="36"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <Path Width="14" Height="14" Margin="0,0,6,0"
                          Fill="White"
                          VerticalAlignment="Center"
                          Data="M4,1 L3,0 L0,0 L0,3 L1,4 L1,1 Z M10,1 L11,0 L14,0 L14,3 L13,4 L13,1 Z M4,13 L3,14 L0,14 L0,11 L1,10 L1,13 Z M10,13 L11,14 L14,14 L14,11 L13,10 L13,13 Z"/>
                    <TextBlock Text="立即截图" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnApply"
                    Click="BtnApply_Click"
                    Content="应用设置"
                    Width="90" Height="36"
                    Background="{StaticResource BackgroundMediumBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderNormalBrush}"
                    BorderThickness="1"
                    FontSize="13"
                    Cursor="Hand"
                    Margin="0,0,10,0"/>

            <Button x:Name="BtnHide"
                    Click="BtnHide_Click"
                    Content="最小化到托盘"
                    Width="110" Height="36"
                    Background="{StaticResource BackgroundMediumBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderNormalBrush}"
                    BorderThickness="1"
                    FontSize="13"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</hc:Window>
