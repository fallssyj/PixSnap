<UserControl
    x:Class="PixSnap.Controls.DockSliderField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Left"
    Focusable="False">
    <StackPanel HorizontalAlignment="Stretch">
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Style="{StaticResource EditDockPropertyLabelStyle}"
                Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource EditDockPropertyValueStyle}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:0}{1}">
                        <Binding Path="Value" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                        <Binding Path="Unit" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Grid>
        <Slider
            HorizontalAlignment="Stretch"
            IsSnapToTickEnabled="True"
            LargeChange="{Binding LargeChange, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}"
            SmallChange="{Binding SmallChange, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Style="{StaticResource EditDockSliderStyle}"
            TickFrequency="{Binding TickFrequency, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Value="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" />
    </StackPanel>
</UserControl>
