<UserControl
    x:Class="PixSnap.Controls.ToolPanels.RoundCornerToolPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    Focusable="False">
    <Border Style="{StaticResource EditDockHostStyle}">
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <controls:DockSliderField
                Label="圆角"
                LargeChange="5"
                Maximum="120"
                Minimum="0"
                SmallChange="1"
                TickFrequency="1"
                Unit="px"
                Value="{Binding RoundCornerPanel.CornerRadius, Mode=TwoWay}" />

            <Border Margin="8,6,18,6" Style="{StaticResource EditDockSeparatorStyle}" />

            <StackPanel Margin="0,8,0,0" Style="{StaticResource EditDockActionsStyle}">
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding RoundCornerPanel.CancelCommand}"
                    Content="取消"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Command="{Binding RoundCornerPanel.ApplyCommand}"
                    CommandParameter="{Binding ScreenshotImage}"
                    Content="应用"
                    Style="{StaticResource PanelApplyButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
