<UserControl
    x:Class="PixSnap.Controls.ToolPanels.EraserToolPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    Focusable="False">
    <Border Style="{StaticResource EditDockToolPanelHostStyle}">
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <StackPanel Style="{StaticResource EditDockToolPanelStripStyle}">
                <controls:DockSliderField
                    Label="画刷"
                    LargeChange="10"
                    Maximum="200"
                    Minimum="5"
                    SmallChange="1"
                    Style="{StaticResource EditDockPropertyFieldSpacingStyle}"
                    TickFrequency="5"
                    Value="{Binding EraserPanel.BrushSize, Mode=TwoWay}" />
                <controls:DockSliderField
                    Label="羽化"
                    LargeChange="10"
                    Maximum="100"
                    Minimum="0"
                    SmallChange="1"
                    TickFrequency="5"
                    Value="{Binding EraserPanel.EdgeFeatherStrength, Mode=TwoWay}" />
            </StackPanel>

            <Border Margin="8,6,18,6" Style="{StaticResource EditDockSeparatorStyle}" />

            <StackPanel Margin="0,8,0,0" Style="{StaticResource EditDockActionsStyle}">
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding EraserPanel.ClearStrokesCommand}"
                    Content="清除"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding ExitEraserModeCommand}"
                    Content="取消"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Command="{Binding ApplyEraserCommand}"
                    CommandParameter="{Binding ScreenshotImage}"
                    Content="应用"
                    Style="{StaticResource PanelApplyButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
