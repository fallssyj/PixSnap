<UserControl
    x:Class="PixSnap.Controls.ToolPanels.EraserToolPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    Focusable="False">
    <Border Style="{StaticResource EditDockHostStyle}">
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <controls:DockSliderField
                Label="画刷"
                LargeChange="10"
                Maximum="200"
                Minimum="5"
                SmallChange="1"
                TickFrequency="5"
                Unit="px"
                Value="{Binding EraserPanel.BrushSize, Mode=TwoWay}" />

            <Border Style="{StaticResource EditDockSeparatorStyle}" />

            <controls:DockSliderField
                Label="羽化"
                LargeChange="10"
                Maximum="100"
                Minimum="0"
                SmallChange="1"
                TickFrequency="5"
                Unit="%"
                Value="{Binding EraserPanel.EdgeFeatherStrength, Mode=TwoWay}" />

            <Border Style="{StaticResource EditDockSeparatorStyle}" />

            <StackPanel Style="{StaticResource EditDockActionsStyle}">
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding EraserPanel.ClearStrokesCommand}"
                    Content="清除"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding ExitEraserModeCommand}"
                    Content="取消"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Command="{Binding ApplyEraserCommand}"
                    CommandParameter="{Binding ScreenshotImage}"
                    Content="应用"
                    Style="{StaticResource PanelApplyButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
