<UserControl
    x:Class="PixSnap.Controls.ToolPanels.EraserToolPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls">
    <controls:FloatingPanel Title="AI 擦除">
        <StackPanel>
            <controls:SliderField
                Label="画刷大小"
                LargeChange="10"
                Maximum="200"
                Minimum="5"
                SmallChange="1"
                TickFrequency="5"
                Unit="px"
                Value="{Binding EraserPanel.BrushSize, Mode=TwoWay}" />
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="边缘羽化" />
                <TextBlock
                    Margin="8,0,0,0"
                    Style="{StaticResource FieldLabelStyle}"
                    Text="{Binding EraserPanel.EdgeFeatherStrengthText}" />
            </StackPanel>
            <Slider
                Margin="0,6,0,0"
                IsSnapToTickEnabled="True"
                LargeChange="10"
                Maximum="100"
                Minimum="0"
                SmallChange="1"
                TickFrequency="5"
                Value="{Binding EraserPanel.EdgeFeatherStrength, Mode=TwoWay}" />
            <StackPanel Style="{StaticResource PanelActionBarStyle}">
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding EraserPanel.ClearStrokesCommand}"
                    Content="清除"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Margin="0,0,6,0"
                    Command="{Binding ExitEraserModeCommand}"
                    Content="取消"
                    Style="{StaticResource PanelCancelButtonStyle}" />
                <Button
                    Command="{Binding ApplyEraserCommand}"
                    CommandParameter="{Binding ScreenshotImage}"
                    Content="应用"
                    Style="{StaticResource PanelApplyButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </controls:FloatingPanel>
</UserControl>
