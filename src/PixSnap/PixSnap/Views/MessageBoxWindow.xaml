<Window
    x:Class="PixSnap.Views.MessageBoxWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PixSnap"
    Width="420"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border
        Background="{DynamicResource AppBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Style="{StaticResource RoundedWindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="13"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="{Binding Title}" />
                <Button
                    Width="44"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding CloseDialogCommand}"
                    Content="{StaticResource close}"
                    Style="{StaticResource CloseIconButton}" />
            </Grid>

            <!--  分隔线  -->
            <Border
                Grid.Row="0"
                Height="1"
                VerticalAlignment="Bottom"
                Background="{DynamicResource BorderBrush}" />

            <!--  内容区  -->
            <Grid Grid.Row="1" Margin="24,20,24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  图标  -->
                <Viewbox
                    Grid.Column="0"
                    Width="28"
                    Height="28"
                    Margin="0,2,14,0"
                    VerticalAlignment="Top"
                    Visibility="{Binding IconVisible, Converter={StaticResource BoolToVis}}">
                    <Path
                        Width="24"
                        Height="24"
                        Data="{Binding IconData}"
                        Fill="{Binding IconBrush}"
                        Stretch="Uniform" />
                </Viewbox>

                <!--  消息文本  -->
                <TextBox
                    Grid.Column="1"
                    MaxHeight="400"
                    Padding="0"
                    Background="Transparent"
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="13.5"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{Binding Message}"
                    TextWrapping="Wrap">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="IsReadOnly" Value="True" />
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>

            <!--  按钮行  -->
            <StackPanel
                Grid.Row="2"
                Margin="24,0,24,20"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Command="{Binding YesCommand}"
                    Content="是"
                    Visibility="{Binding ShowYes, Converter={StaticResource BoolToVis}}" />
                <Button
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Command="{Binding NoCommand}"
                    Content="否"
                    Visibility="{Binding ShowNo, Converter={StaticResource BoolToVis}}" />
                <Button
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Command="{Binding OkCommand}"
                    Content="确定"
                    Visibility="{Binding ShowOk, Converter={StaticResource BoolToVis}}" />
                <Button
                    MinWidth="80"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Visibility="{Binding ShowCancel, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

