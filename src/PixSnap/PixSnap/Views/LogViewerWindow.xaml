<Window
    x:Class="PixSnap.Views.LogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:PixSnap.Behaviors"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:PixSnap.ViewModels"
    Title="日志查看器"
    Width="900"
    Height="600"
    MinWidth="640"
    MinHeight="400"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    ui:TitleBar.Height="36">

    <DockPanel>
        <Border Padding="24,16,24,12" DockPanel.Dock="Top">
            <controls:PageHeader Subtitle="查看运行日志与诊断信息" Title="日志">
                <controls:PageHeader.IconContent>
                    <ui:FontIcon
                        FontSize="18"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        Icon="{x:Static ui:SegoeFluentIcons.Diagnostic}" />
                </controls:PageHeader.IconContent>
            </controls:PageHeader>
        </Border>

        <Border
            Height="1"
            Margin="24,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}"
            DockPanel.Dock="Top" />

        <Border
            Padding="24,12,24,8"
            DockPanel.Dock="Top">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding SelectedFileName, StringFormat=当前文件：{0}}" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding OpenLogDirectoryCommand}"
                        Content="打开日志目录"
                        Style="{StaticResource PixSnapButtonStyle}" />
                    <Button
                        Command="{Binding ClearLogsCommand}"
                        Content="清空日志"
                        Style="{StaticResource PixSnapButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="0,0,8,0"
                Style="{StaticResource SettingsGroupCardStyle}">
                <TreeView
                    Margin="4"
                    Background="Transparent"
                    BorderThickness="0"
                    behaviors:TreeViewSelectedItemBehavior.SelectedItem="{Binding SelectedLogItem, Mode=TwoWay}"
                    ItemsSource="{Binding LogTree}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:LogDateGroup}" ItemsSource="{Binding Children}">
                            <TextBlock
                                Padding="2"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding Header}" />
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource {x:Type TreeViewItem}}" TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneTime}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <Border Grid.Column="2" Style="{StaticResource SettingsGroupCardStyle}">
                <TextBox
                    x:Name="LogContentTextBox"
                    Margin="4"
                    Padding="8"
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="{StaticResource AppFontFamilyMono}"
                    FontSize="{StaticResource AppFontSizeCaption}"
                    HorizontalScrollBarVisibility="Auto"
                    IsReadOnly="True"
                    Text="{Binding LogContent, Mode=OneWay}"
                    TextWrapping="NoWrap"
                    VerticalScrollBarVisibility="Auto" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
