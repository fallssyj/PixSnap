<mica:MicaWindow
    x:Class="PixSnap.Views.LogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
    xmlns:vm="clr-namespace:PixSnap.ViewModels"
    Title="日志查看器"
    Width="900"
    Height="600"
    MinWidth="640"
    MinHeight="400"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="-1"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border>
        <DockPanel>
            <!--  标题栏  -->
            <Border
                Padding="16,0,0,0"
                Background="Transparent"
                DockPanel.Dock="Top"
                MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="44">
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource SegoeFluent}"
                            FontSize="14"
                            Foreground="{DynamicResource AccentBrush}"
                            Text="{StaticResource Glyph_Preview}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Medium"
                            Text="日志查看器" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Opacity="0.4"
                            Text="{Binding SelectedFileName}" />
                    </StackPanel>
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding CloseCommand}"
                        Content="{StaticResource Glyph_Close}"
                        Style="{StaticResource CloseWindowIconButtonStyle}" />
                </Grid>
            </Border>

            <Border
                Height="1"
                Background="{DynamicResource BorderBrush}"
                DockPanel.Dock="Top" />

            <!--  主体  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  左侧：日志树  -->
                <TreeView
                    x:Name="LogTreeView"
                    Grid.Column="0"
                    Margin="8"
                    ItemsSource="{Binding LogTree}"
                    SelectedItemChanged="OnLogTreeSelectedItemChanged"
                    Style="{StaticResource LogTreeViewStyle}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:LogDateGroup}" ItemsSource="{Binding Children}">
                            <TextBlock Padding="2" Text="{Binding Header}" />
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource TreeViewItemStyle}" TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneTime}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!--  分隔线  -->
                <GridSplitter
                    Grid.Column="1"
                    Width="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource BorderBrush}" />

                <!--  右侧：日志内容  -->
                <TextBox
                    Grid.Column="2"
                    Margin="8"
                    Padding="8"
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    FontFamily="Consolas, Cascadia Code, 等距更纱黑体"
                    FontSize="12"
                    HorizontalScrollBarVisibility="Auto"
                    IsReadOnly="True"
                    Text="{Binding LogContent, Mode=OneWay}"
                    TextWrapping="NoWrap"
                    VerticalScrollBarVisibility="Auto">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="CaretBrush" Value="{DynamicResource AccentInfoBrush}" />
                            <Setter Property="SelectionBrush" Value="{DynamicResource InputSelectionBrush}" />
                            <Setter Property="SelectionOpacity" Value="0.5" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Setter Property="UseLayoutRounding" Value="True" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </DockPanel>
    </Border>
</mica:MicaWindow>
