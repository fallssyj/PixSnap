<Window
    x:Class="PixSnap.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="关于 PixSnap"
    Width="560"
    Height="700"
    MinWidth="480"
    MinHeight="560"
    ResizeMode="CanResize"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:TitleBar.Height="36"
    ui:TitleBar.MaximizeButtonAvailability="Collapsed"
    ui:TitleBar.MinimizeButtonAvailability="Collapsed"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,22,28,10">
            <controls:PageHeader Subtitle="截图、录屏与本地 AI 编辑工具" Title="关于">
                <controls:PageHeader.IconContent>
                    <ui:FontIcon
                        FontSize="18"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        Icon="{x:Static ui:SegoeFluentIcons.Info}" />
                </controls:PageHeader.IconContent>
            </controls:PageHeader>
        </Border>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="28,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Row="2"
            Padding="28,14,28,8"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ikw:SimpleStackPanel MaxWidth="520" Spacing="16">

                <!--  品牌区  -->
                <Border Style="{StaticResource AboutHeroCardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource AboutAppIconHostStyle}">
                            <Image
                                Width="52"
                                Height="52"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="/Assets/icons/app.png"
                                Stretch="Uniform" />
                        </Border>
                        <TextBlock
                            Margin="0,14,0,0"
                            HorizontalAlignment="Center"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="PixSnap" />
                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="基于 Windows Graphics Capture 与 ONNX 本地推理"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <Border Style="{StaticResource AboutVersionBadgeStyle}">
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding Version}" />
                        </Border>
                    </StackPanel>
                </Border>

                <!--  核心功能  -->
                <StackPanel>
                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="核心功能" />
                    <UniformGrid Columns="2">
                        <Border Margin="0,0,6,6" Style="{StaticResource AboutFeatureTileStyle}">
                            <StackPanel>
                                <Border HorizontalAlignment="Left" Style="{StaticResource AboutFeatureIconHostStyle}">
                                    <ui:FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Icon="{x:Static ui:SegoeFluentIcons.Crop}"
                                        Style="{StaticResource AboutFeatureIconStyle}" />
                                </Border>
                                <TextBlock Style="{StaticResource AboutFeatureTitleStyle}" Text="截图" />
                                <TextBlock Style="{StaticResource AboutFeatureDescStyle}" Text="窗口、矩形、全屏三种模式" />
                            </StackPanel>
                        </Border>
                        <Border Margin="6,0,0,6" Style="{StaticResource AboutFeatureTileStyle}">
                            <StackPanel>
                                <Border HorizontalAlignment="Left" Style="{StaticResource AboutFeatureIconHostStyle}">
                                    <ui:FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Icon="{x:Static ui:SegoeFluentIcons.Video}"
                                        Style="{StaticResource AboutFeatureIconStyle}" />
                                </Border>
                                <TextBlock Style="{StaticResource AboutFeatureTitleStyle}" Text="录屏" />
                                <TextBlock Style="{StaticResource AboutFeatureDescStyle}" Text="H.264 视频与 AAC 音频，支持暂停" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,6,6,0" Style="{StaticResource AboutFeatureTileStyle}">
                            <StackPanel>
                                <Border HorizontalAlignment="Left" Style="{StaticResource AboutFeatureIconHostStyle}">
                                    <ui:FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Icon="{x:Static ui:SegoeFluentIcons.Highlight}"
                                        Style="{StaticResource AboutFeatureIconStyle}" />
                                </Border>
                                <TextBlock Style="{StaticResource AboutFeatureTitleStyle}" Text="标注" />
                                <TextBlock Style="{StaticResource AboutFeatureDescStyle}" Text="箭头、文字、画笔、马赛克等工具" />
                            </StackPanel>
                        </Border>
                        <Border Margin="6,6,0,0" Style="{StaticResource AboutFeatureTileStyle}">
                            <StackPanel>
                                <Border HorizontalAlignment="Left" Style="{StaticResource AboutFeatureIconHostStyle}">
                                    <ui:FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Icon="{x:Static ui:SegoeFluentIcons.Font}"
                                        Style="{StaticResource AboutFeatureIconStyle}" />
                                </Border>
                                <TextBlock Style="{StaticResource AboutFeatureTitleStyle}" Text="OCR" />
                                <TextBlock Style="{StaticResource AboutFeatureDescStyle}" Text="PaddleOCR 离线识别图片文字" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <!--  AI 能力  -->
                <StackPanel>
                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="AI 本地推理" />
                    <Border Style="{StaticResource SettingsGroupCardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon
                                        Icon="{x:Static ui:SegoeFluentIcons.EraseTool}"
                                        Style="{StaticResource AboutListIconStyle}" />
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="AI 擦除" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="涂抹区域智能修复" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon
                                        Icon="{x:Static ui:SegoeFluentIcons.Color}"
                                        Style="{StaticResource AboutListIconStyle}" />
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="背景去除" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="一键抠图，数据不上传" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon
                                        Icon="{x:Static ui:SegoeFluentIcons.ZoomIn}"
                                        Style="{StaticResource AboutListIconStyle}" />
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="超分辨率" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="Real-ESRGAN 放大增强" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <TextBlock
                        Margin="4,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="DirectML GPU 加速，可在设置中切换设备" />
                </StackPanel>

                <!--  截图快捷键  -->
                <StackPanel>
                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="截图快捷键" />
                    <Border Style="{StaticResource SettingsGroupCardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Icon="{x:Static ui:SegoeFluentIcons.WindowSnipping}"
                                            Style="{StaticResource AboutListIconStyle}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SettingsRowTitleStyle}"
                                            Text="窗口截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="左键单击" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Icon="{x:Static ui:SegoeFluentIcons.Crop}"
                                            Style="{StaticResource AboutListIconStyle}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SettingsRowTitleStyle}"
                                            Text="矩形截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="左键拖动" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Icon="{x:Static ui:SegoeFluentIcons.FullScreen}"
                                            Style="{StaticResource AboutListIconStyle}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SettingsRowTitleStyle}"
                                            Text="全屏截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="Space" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource AboutListRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Icon="{x:Static ui:SegoeFluentIcons.Cancel}"
                                            Style="{StaticResource AboutListIconStyle}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SettingsRowTitleStyle}"
                                            Text="退出截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="Esc / 右键" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!--  链接  -->
                <StackPanel>
                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="开源与反馈" />
                    <Border Padding="14,12" Style="{StaticResource SettingsGroupCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Icon="{x:Static ui:SegoeFluentIcons.OpenInNewWindow}"
                                Style="{StaticResource AboutListIconStyle}" />
                            <ui:HyperlinkButton
                                Content="GitHub 仓库"
                                NavigateUri="{Binding RepositoryUrl}"
                                Style="{StaticResource AboutLinkButtonStyle}" />
                            <ui:FontIcon
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Icon="{x:Static ui:SegoeFluentIcons.Feedback}"
                                Style="{StaticResource AboutListIconStyle}" />
                            <ui:HyperlinkButton
                                Content="反馈问题"
                                NavigateUri="{Binding IssuesUrl}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </ikw:SimpleStackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            Padding="28,12,28,18"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Copyright © 2026 PixSnap Contributors" />
        </Border>
    </Grid>
</Window>
