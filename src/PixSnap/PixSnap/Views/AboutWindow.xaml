<Window
    x:Class="PixSnap.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="关于 PixSnap"
    Width="520"
    Height="640"
    MinWidth="460"
    MinHeight="520"
    ResizeMode="CanResize"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:TitleBar.Height="36"
    ui:TitleBar.MaximizeButtonAvailability="Collapsed"
    ui:TitleBar.MinimizeButtonAvailability="Collapsed"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="32,24,32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="64"
                    Height="64"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="14">
                    <Image
                        Width="48"
                        Height="48"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="/Assets/icons/app.png"
                        Stretch="Uniform" />
                </Border>
                <StackPanel
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="PixSnap" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="截图 · 录屏 · 标注 · AI 编辑" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Version}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="32,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Row="2"
            Padding="32,12,32,8"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <ikw:SimpleStackPanel MaxWidth="560" Spacing="4">
                    <TextBlock
                        Margin="4,0,0,4"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="基于 Windows Graphics Capture 与 ONNX 本地推理，AI 能力完全离线可用。"
                        TextWrapping="Wrap" />

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="功能" />

                    <ui:SettingsCard
                        Description="窗口、矩形、全屏三种模式"
                        Header="截图"
                        IsActionIconVisible="False">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon
                                FontSize="16"
                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                Icon="{x:Static ui:SegoeFluentIcons.Crop}" />
                        </ui:SettingsCard.HeaderIcon>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="H.264 视频 + AAC 音频，支持暂停与恢复"
                        Header="录屏"
                        IsActionIconVisible="False">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon
                                FontSize="16"
                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                Icon="{x:Static ui:SegoeFluentIcons.Video}" />
                        </ui:SettingsCard.HeaderIcon>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="箭头、文字、画笔、马赛克等标注工具"
                        Header="标注编辑"
                        IsActionIconVisible="False">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon
                                FontSize="16"
                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                Icon="{x:Static ui:SegoeFluentIcons.Highlight}" />
                        </ui:SettingsCard.HeaderIcon>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="识别图片中的文字内容"
                        Header="OCR 识别"
                        IsActionIconVisible="False">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon
                                FontSize="16"
                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                Icon="{x:Static ui:SegoeFluentIcons.Font}" />
                        </ui:SettingsCard.HeaderIcon>
                    </ui:SettingsCard>

                    <ui:SettingsExpander
                        Description="DirectML GPU 本地推理，数据不上传"
                        Header="AI 能力"
                        IsExpanded="True">
                        <ui:SettingsExpander.HeaderIcon>
                            <ui:FontIcon
                                FontSize="16"
                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                Icon="{x:Static ui:SegoeFluentIcons.Diagnostic}" />
                        </ui:SettingsExpander.HeaderIcon>
                        <ui:SettingsExpander.Items>
                            <ui:SettingsCard
                                Description="涂抹区域自动修复"
                                Header="AI 擦除"
                                IsActionIconVisible="False">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon
                                        FontSize="16"
                                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                        Icon="{x:Static ui:SegoeFluentIcons.EraseTool}" />
                                </ui:SettingsCard.HeaderIcon>
                            </ui:SettingsCard>
                            <ui:SettingsCard
                                Description="一键去除图片背景"
                                Header="背景去除"
                                IsActionIconVisible="False">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon
                                        FontSize="16"
                                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                        Icon="{x:Static ui:SegoeFluentIcons.Color}" />
                                </ui:SettingsCard.HeaderIcon>
                            </ui:SettingsCard>
                            <ui:SettingsCard
                                Description="Real-ESRGAN 4× 放大增强"
                                Header="超分辨率"
                                IsActionIconVisible="False">
                                <ui:SettingsCard.HeaderIcon>
                                    <ui:FontIcon
                                        FontSize="16"
                                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                        Icon="{x:Static ui:SegoeFluentIcons.ZoomIn}" />
                                </ui:SettingsCard.HeaderIcon>
                            </ui:SettingsCard>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="快捷操作" />

                    <Border Style="{StaticResource SettingsGroupCardStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsCardRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Style="{StaticResource SettingsRowIconStyle}"
                                            Icon="{x:Static ui:SegoeFluentIcons.WindowSnipping}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="窗口截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="左键单击" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource SettingsCardRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Style="{StaticResource SettingsRowIconStyle}"
                                            Icon="{x:Static ui:SegoeFluentIcons.Crop}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="矩形截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="左键拖动" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource SettingsCardRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Style="{StaticResource SettingsRowIconStyle}"
                                            Icon="{x:Static ui:SegoeFluentIcons.FullScreen}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="全屏截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="Space" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border
                                Height="1"
                                Margin="16,0"
                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <Border Style="{StaticResource SettingsCardRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon
                                            Style="{StaticResource SettingsRowIconStyle}"
                                            Icon="{x:Static ui:SegoeFluentIcons.Cancel}" />
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="退出截图" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource AboutShortcutKeyStyle}">
                                        <TextBlock FontSize="12" Text="Esc / 右键" />
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="链接" />

                    <ui:SettingsCard ContentAlignment="Left" Header="获取源码与反馈">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon
                                FontSize="16"
                                Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                Icon="{x:Static ui:SegoeFluentIcons.Info}" />
                        </ui:SettingsCard.HeaderIcon>
                        <StackPanel Margin="-12,0,0,0">
                            <ui:HyperlinkButton Content="GitHub 仓库" NavigateUri="{Binding RepositoryUrl}" />
                            <ui:HyperlinkButton Content="反馈问题" NavigateUri="{Binding IssuesUrl}" />
                        </StackPanel>
                    </ui:SettingsCard>
                </ikw:SimpleStackPanel>
            </Grid>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            Padding="32,12,32,20"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Copyright © 2026 PixSnap Contributors" />
        </Border>
    </Grid>
</Window>
