<mica:MicaWindow
    x:Class="PixSnap.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
    Title="关于 PixSnap"
    Width="520"
    Height="640"
    ResizeMode="NoResize"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="-1"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border>
        <Grid>
            <!--  关闭按钮  -->
            <Button
                Width="44"
                Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="10"
                Command="{Binding CloseCommand}"
                Content="{StaticResource Glyph_Close}"
                Style="{StaticResource CloseWindowIconButtonStyle}" />

            <DockPanel>
                <!--  ═══  Hero 区域  ═══  -->
                <Border
                    Padding="0,40,0,32"
                    ClipToBounds="True"
                    DockPanel.Dock="Top"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                    <Border.Background>
                        <LinearGradientBrush x:Name="HeroGradient" StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#20845EF7" />
                            <GradientStop Offset="0.5" Color="#104568DC" />
                            <GradientStop Offset="1" Color="#0822B8CF" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                    <PointAnimation
                                        Storyboard.TargetName="HeroGradient"
                                        Storyboard.TargetProperty="StartPoint"
                                        To="1,0"
                                        Duration="0:0:6">
                                        <PointAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </PointAnimation.EasingFunction>
                                    </PointAnimation>
                                    <PointAnimation
                                        Storyboard.TargetName="HeroGradient"
                                        Storyboard.TargetProperty="EndPoint"
                                        To="0,1"
                                        Duration="0:0:6">
                                        <PointAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </PointAnimation.EasingFunction>
                                    </PointAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>

                    <Grid>
                        <!--  装饰光晕  -->
                        <Ellipse
                            Width="200"
                            Height="200"
                            Margin="0,-20,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False"
                            Opacity="0.06">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Offset="0" Color="#845EF7" />
                                    <GradientStop Offset="1" Color="Transparent" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <StackPanel HorizontalAlignment="Center">
                            <!--  应用图标  -->
                            <Grid HorizontalAlignment="Center">
                                <Border
                                    x:Name="IconGlow"
                                    Width="88"
                                    Height="88"
                                    HorizontalAlignment="Center"
                                    CornerRadius="22"
                                    IsHitTestVisible="False"
                                    Opacity="0">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Offset="0.3" Color="#40845EF7" />
                                            <GradientStop Offset="1" Color="Transparent" />
                                        </RadialGradientBrush>
                                    </Border.Background>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="IconGlow"
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="0"
                                                        To="1"
                                                        Duration="0:0:2.5">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                                <Border
                                    Width="64"
                                    Height="64"
                                    HorizontalAlignment="Center"
                                    CornerRadius="16">
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="20"
                                            Opacity="0.35"
                                            ShadowDepth="6"
                                            Color="#845EF7" />
                                    </Border.Effect>
                                    <Border.Background>
                                        <ImageBrush ImageSource="/Assets/icons/app.png" Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>
                            </Grid>

                            <TextBlock
                                Margin="0,14,0,0"
                                HorizontalAlignment="Center"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="PixSnap" />

                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="13"
                                Opacity="0.5"
                                Text="截图 · 录屏 · 标注 · AI 编辑" />

                            <!--  版本徽章  -->
                            <Border
                                Margin="0,12,0,0"
                                Padding="14,5"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource HeroBadgeBackgroundBrush}"
                                CornerRadius="12">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse
                                        Width="6"
                                        Height="6"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Fill="{DynamicResource HeroBadgeIndicatorBrush}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource HeroBadgeForegroundBrush}"
                                        Text="{Binding Version}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  分隔线  -->
                <Border
                    Height="1"
                    Margin="24,0"
                    Background="{DynamicResource BorderBrush}"
                    DockPanel.Dock="Top" />

                <!--  版权（底部固定）  -->
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    DockPanel.Dock="Bottom"
                    FontSize="12"
                    Opacity="0.25"
                    Text="Copyright © 2026 PixSnap Contributors" />

                <!--  可滚动内容区  -->
                <ScrollViewer
                    Padding="24,16,24,8"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!--  ═══  核心功能  ═══  -->
                        <TextBlock
                            Margin="4,0,0,10"
                            FontSize="13"
                            Opacity="0.4"
                            Text="核心功能" />

                        <!--  截图 + 录屏 两列  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  截图  -->
                            <Border
                                Grid.Column="0"
                                Padding="16,16"
                                Background="{DynamicResource FeatureWindowBackgroundBrush}"
                                CornerRadius="12">
                                <StackPanel>
                                    <Grid>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Left"
                                            Background="#15845EF7"
                                            CornerRadius="9">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluent}"
                                                FontSize="16"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="{StaticResource Glyph_Crop}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontSize="14"
                                        FontWeight="Medium"
                                        Text="截图" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Opacity="0.5"
                                        Text="窗口 · 矩形 · 全屏"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!--  录屏  -->
                            <Border
                                Grid.Column="2"
                                Padding="16,16"
                                Background="{DynamicResource FeatureRegionBackgroundBrush}"
                                CornerRadius="12">
                                <StackPanel>
                                    <Grid>
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Left"
                                            Background="#15E64980"
                                            CornerRadius="9">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluent}"
                                                FontSize="16"
                                                Foreground="#E64980"
                                                Text="{StaticResource Glyph_Play}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontSize="14"
                                        FontWeight="Medium"
                                        Text="录屏" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Opacity="0.5"
                                        Text="H.264 + AAC · 暂停恢复"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!--  ═══  编辑 & AI  ═══  -->
                        <TextBlock
                            Margin="4,18,0,10"
                            FontSize="13"
                            Opacity="0.4"
                            Text="编辑 &amp; AI" />

                        <Border
                            Padding="4,14"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  标注  -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        Background="#15845EF7"
                                        CornerRadius="9">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource SegoeFluent}"
                                            FontSize="15"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Text="{StaticResource Glyph_Annotate}" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Text="标注" />
                                </StackPanel>

                                <!--  裁剪  -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        Background="#15845EF7"
                                        CornerRadius="9">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource SegoeFluent}"
                                            FontSize="15"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Text="{StaticResource Glyph_Crop}" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Text="裁剪" />
                                </StackPanel>

                                <!--  AI 擦除  -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        Background="#1540C057"
                                        CornerRadius="9">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource SegoeFluent}"
                                            FontSize="15"
                                            Foreground="#40C057"
                                            Text="{StaticResource Glyph_Eraser}" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Text="AI 擦除" />
                                </StackPanel>

                                <!--  去背景  -->
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        Background="#15F59F00"
                                        CornerRadius="9">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource SegoeFluent}"
                                            FontSize="15"
                                            Foreground="#F59F00"
                                            Text="{StaticResource Glyph_Color}" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Text="去背景" />
                                </StackPanel>

                                <!--  超分  -->
                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <Border
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        Background="#1522B8CF"
                                        CornerRadius="9">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource SegoeFluent}"
                                            FontSize="15"
                                            Foreground="#22B8CF"
                                            Text="{StaticResource Glyph_ZoomIn}" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Text="超分 4×" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--  ═══  快捷键提示  ═══  -->
                        <TextBlock
                            Margin="4,18,0,10"
                            FontSize="13"
                            Opacity="0.4"
                            Text="快捷操作" />

                        <Border
                            Padding="0"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12">
                            <StackPanel>
                                <!--  行模板  -->
                                <Border Padding="16,11">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluent}"
                                                FontSize="14"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="{StaticResource Glyph_Maximize}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Text="窗口截图" />
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Opacity="0.4"
                                            Text="左键单击" />
                                    </Grid>
                                </Border>
                                <Border
                                    Height="1"
                                    Margin="40,0,16,0"
                                    Background="{DynamicResource BorderBrush}" />
                                <Border Padding="16,11">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluent}"
                                                FontSize="14"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="{StaticResource Glyph_Crop}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Text="矩形截图" />
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Opacity="0.4"
                                            Text="左键拖动" />
                                    </Grid>
                                </Border>
                                <Border
                                    Height="1"
                                    Margin="40,0,16,0"
                                    Background="{DynamicResource BorderBrush}" />
                                <Border Padding="16,11">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluent}"
                                                FontSize="14"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="{StaticResource Glyph_Resolution}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Text="全屏截图" />
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Opacity="0.4"
                                            Text="Space" />
                                    </Grid>
                                </Border>
                                <Border
                                    Height="1"
                                    Margin="40,0,16,0"
                                    Background="{DynamicResource BorderBrush}" />
                                <Border Padding="16,11">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluent}"
                                                FontSize="14"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="{StaticResource Glyph_Close}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Text="退出截图" />
                                        </StackPanel>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Opacity="0.4"
                                            Text="Esc / 右键" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</mica:MicaWindow>
