<mica:MicaWindow
    x:Class="PixSnap.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
    Title="{StaticResource S_About_Title}"
    Width="480"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="-1"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border
        Background="{DynamicResource AppBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock
                    Margin="18,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="13"
                    Text="{StaticResource S_About_Title}" />
                <Button
                    Width="44"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource CloseIconButton}">
                    <TextBlock
                        FontFamily="{StaticResource SegoeFluent}"
                        FontSize="10"
                        Text="{StaticResource Glyph_Close}" />
                </Button>
            </Grid>

            <!--  分隔线  -->
            <Border
                Grid.Row="0"
                Height="1"
                VerticalAlignment="Bottom"
                Background="{DynamicResource BorderBrush}" />

            <!--  主体内容  -->
            <StackPanel Grid.Row="1" Margin="{DynamicResource DialogContentPadding}">

                <!--  应用名称 + 版本  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="{StaticResource MiSansRegular}"
                            FontSize="26"
                            Text="PixSnap" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource MiSansRegular}"
                            FontSize="13"
                            Opacity="0.6"
                            Text="{StaticResource S_About_Subtitle}" />
                    </StackPanel>

                    <!--  版本徽章  -->
                    <Border
                        Grid.Column="1"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        Background="{DynamicResource HeroBadgeBackgroundBrush}"
                        CornerRadius="8">
                        <TextBlock
                            FontFamily="{StaticResource MiSansRegular}"
                            FontSize="13"
                            Text="{Binding Version}" />
                    </Border>
                </Grid>

                <!--  截图模式说明标题  -->
                <TextBlock
                    Margin="0,20,0,10"
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="13"
                    Opacity="0.6"
                    Text="{StaticResource S_About_ModeGuide}" />

                <!--  功能卡片  -->
                <Border
                    Padding="14"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                    <UniformGrid Columns="2" Rows="2">
                        <!--  窗口  -->
                        <Border
                            Margin="0,0,6,6"
                            Padding="12"
                            Background="{DynamicResource FeatureWindowBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource MiSansRegular}" Text="{StaticResource S_About_ModeWindow}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontFamily="{StaticResource MiSansRegular}"
                                    FontSize="12"
                                    Opacity="0.6"
                                    Text="{StaticResource S_About_ModeWindowDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <!--  矩形  -->
                        <Border
                            Margin="6,0,0,6"
                            Padding="12"
                            Background="{DynamicResource FeatureRegionBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource MiSansRegular}" Text="{StaticResource S_About_ModeRect}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontFamily="{StaticResource MiSansRegular}"
                                    FontSize="12"
                                    Opacity="0.6"
                                    Text="{StaticResource S_About_ModeRectDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <!--  当前屏幕  -->
                        <Border
                            Margin="0,6,6,0"
                            Padding="12"
                            Background="{DynamicResource FeatureMonitorBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource MiSansRegular}" Text="{StaticResource S_About_ModeScreen}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontFamily="{StaticResource MiSansRegular}"
                                    FontSize="12"
                                    Opacity="0.6"
                                    Text="{StaticResource S_About_ModeScreenDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <!--  退出  -->
                        <Border
                            Margin="6,6,0,0"
                            Padding="12"
                            Background="{DynamicResource FeatureExitBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource MiSansRegular}" Text="{StaticResource S_About_ModeExit}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontFamily="{StaticResource MiSansRegular}"
                                    FontSize="12"
                                    Opacity="0.6"
                                    Text="{StaticResource S_About_ModeExitDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Border>

                <!--  版权信息  -->
                <TextBlock
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="12"
                    Opacity="0.6"
                    Text="Copyright © 2026 PixSnap Contributors" />

            </StackPanel>
        </Grid>
    </Border>
</mica:MicaWindow>
