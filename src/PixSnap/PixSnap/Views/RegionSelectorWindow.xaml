<Window
    x:Class="PixSnap.Views.RegionSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="Region Selector"
    AllowsTransparency="True"
    Background="Transparent"
    Cursor="None"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Canvas x:Name="RootCanvas" Background="#01000000">
        <!--  这些命名元素由 code-behind 直接更新，用于高频覆盖层绘制，避免把 Canvas 坐标细节泄漏到 ViewModel。  -->
        <Rectangle
            x:Name="Mask"
            Width="0"
            Height="0"
            Fill="{DynamicResource OverlayMaskBrush}" />
        <Rectangle
            x:Name="WindowHighlightRect"
            Fill="{DynamicResource OverlayWindowHighlightFillBrush}"
            Stroke="{DynamicResource OverlayWindowHighlightStrokeBrush}"
            StrokeThickness="3"
            Visibility="Collapsed" />
        <Rectangle
            x:Name="SelectionRect"
            Fill="{DynamicResource OverlaySelectionFillBrush}"
            Stroke="{DynamicResource OverlaySelectionStrokeBrush}"
            StrokeThickness="2"
            Visibility="Collapsed" />

        <Border
            x:Name="InfoBubble"
            Padding="12,10"
            Background="{DynamicResource OverlayInfoBubbleBackgroundBrush}"
            CornerRadius="14"
            IsHitTestVisible="False">
            <StackPanel>
                <TextBlock
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding SelectionText}" />
                <TextBlock
                    MaxWidth="420"
                    Margin="0,6,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding InstructionText}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border
            x:Name="FooterHint"
            Padding="14,10"
            Background="{DynamicResource OverlayFooterBackgroundBrush}"
            CornerRadius="16"
            IsHitTestVisible="False">
            <TextBlock
                MaxWidth="520"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="{Binding FooterHintText}"
                TextWrapping="Wrap" />
        </Border>

        <!--  自定义十字准星：全屏辅助线 + 中心十字（带间隙）  -->
        <Line
            x:Name="GuideV"
            IsHitTestVisible="False"
            Opacity="0.4"
            Stroke="#55FFFFFF"
            StrokeDashArray="4 4"
            StrokeThickness="1" />
        <Line
            x:Name="GuideH"
            IsHitTestVisible="False"
            Opacity="0.4"
            Stroke="#55FFFFFF"
            StrokeDashArray="4 4"
            StrokeThickness="1" />
        <Line
            x:Name="CrossOT"
            IsHitTestVisible="False"
            Stroke="#CC000000"
            StrokeThickness="3" />
        <Line
            x:Name="CrossOB"
            IsHitTestVisible="False"
            Stroke="#CC000000"
            StrokeThickness="3" />
        <Line
            x:Name="CrossOL"
            IsHitTestVisible="False"
            Stroke="#CC000000"
            StrokeThickness="3" />
        <Line
            x:Name="CrossOR"
            IsHitTestVisible="False"
            Stroke="#CC000000"
            StrokeThickness="3" />
        <Line
            x:Name="CrossIT"
            IsHitTestVisible="False"
            Stroke="White"
            StrokeThickness="1" />
        <Line
            x:Name="CrossIB"
            IsHitTestVisible="False"
            Stroke="White"
            StrokeThickness="1" />
        <Line
            x:Name="CrossIL"
            IsHitTestVisible="False"
            Stroke="White"
            StrokeThickness="1" />
        <Line
            x:Name="CrossIR"
            IsHitTestVisible="False"
            Stroke="White"
            StrokeThickness="1" />

        <!--  截屏 / 录屏 模式切换  -->
        <Border
            x:Name="ModeTogglePanel"
            Padding="4"
            Background="{DynamicResource OverlayInfoBubbleBackgroundBrush}"
            CornerRadius="12"
            IsHitTestVisible="True">
            <StackPanel Orientation="Horizontal">
                <Button
                    Command="{Binding SelectScreenshotModeCommand}"
                    Content="截屏"
                    FontSize="13">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecordingMode}" Value="False">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Command="{Binding SelectRecordingModeCommand}"
                    Content="录屏"
                    FontSize="13">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecordingMode}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Border
                    Width="1"
                    Margin="4,4"
                    Background="{DynamicResource OverlayFooterForegroundBrush}"
                    Opacity="0.3"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}" />
                <Button
                    Command="{Binding ToggleMicrophoneCommand}"
                    ToolTip="麦克风"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EnableMicrophone}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnableMicrophone}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <ui:FontIcon FontSize="15" Icon="{x:Static ui:SegoeFluentIcons.Microphone}" />
                </Button>
                <Button
                    Command="{Binding ToggleSystemAudioCommand}"
                    ToolTip="系统声音"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EnableSystemAudio}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnableSystemAudio}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <ui:FontIcon FontSize="15" Icon="{x:Static ui:SegoeFluentIcons.Volume}" />
                </Button>

                <Border
                    Width="1"
                    Margin="4,4"
                    Background="{DynamicResource OverlayFooterForegroundBrush}"
                    Opacity="0.3"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}" />
                <Button
                    Command="{Binding SetQualityStandardCommand}"
                    Content="标清"
                    FontSize="12"
                    ToolTip="标清"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQualityStandard}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsQualityStandard}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Command="{Binding SetQualityHighCommand}"
                    Content="高清"
                    FontSize="12"
                    ToolTip="高清"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQualityHigh}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsQualityHigh}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Command="{Binding SetQualityOriginalCommand}"
                    Content="原画"
                    FontSize="12"
                    ToolTip="原画"
                    Visibility="{Binding ShowRecordingOptions, Converter={StaticResource BoolToVisibility}}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource OverlayChipButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQualityOriginal}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource OverlaySelectionStrokeBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource OverlayAccentForegroundBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsQualityOriginal}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Canvas>
</Window>