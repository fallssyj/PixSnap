<Window
    x:Class="PixSnap.Views.RegionSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Region Selector"
    AllowsTransparency="True"
    Background="Transparent"
    Cursor="Cross"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">
    <Canvas x:Name="RootCanvas" Background="#01000000">
        <!--  这些命名元素由 code-behind 直接更新，用于高频覆盖层绘制，避免把 Canvas 坐标细节泄漏到 ViewModel。  -->
        <Rectangle
            x:Name="Mask"
            Width="0"
            Height="0"
            Fill="{DynamicResource OverlayMaskBrush}" />
        <Rectangle
            x:Name="WindowHighlightRect"
            Fill="{DynamicResource OverlayWindowHighlightFillBrush}"
            Stroke="{DynamicResource OverlayWindowHighlightStrokeBrush}"
            StrokeThickness="3"
            Visibility="Collapsed" />
        <Rectangle
            x:Name="SelectionRect"
            Fill="{DynamicResource OverlaySelectionFillBrush}"
            Stroke="{DynamicResource OverlaySelectionStrokeBrush}"
            StrokeThickness="2"
            Visibility="Collapsed" />

        <Border
            x:Name="InfoBubble"
            Padding="12,10"
            Background="{DynamicResource OverlayInfoBubbleBackgroundBrush}"
            CornerRadius="14"
            IsHitTestVisible="False">
            <StackPanel>
                <TextBlock FontSize="13" Text="{Binding SelectionText}" />
                <TextBlock
                    MaxWidth="420"
                    Margin="0,6,0,0"
                    FontSize="12"
                    Text="{Binding InstructionText}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border
            x:Name="FooterHint"
            Padding="14,10"
            Background="{DynamicResource OverlayFooterBackgroundBrush}"
            CornerRadius="16"
            IsHitTestVisible="False">
            <TextBlock
                MaxWidth="520"
                Text="左键单击高亮窗口截图，左键拖动截矩形，Space 截当前显示器，Esc / 右键退出"
                TextWrapping="Wrap" />
        </Border>
    </Canvas>
</Window>