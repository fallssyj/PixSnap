<Window
    x:Class="PixSnap.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PixSnap"
    Width="760"
    Height="650"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="{StaticResource ColorAppGradientStart}" />
                <GradientStop Offset="0.55" Color="{StaticResource ColorAppGradientMid}" />
                <GradientStop Offset="1" Color="{StaticResource ColorAppGradientEnd}" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="30"
                        FontWeight="Bold"
                        Text="PixSnap" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="15"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Text="进入一次截图界面，用鼠标直接决定截图模式。" />
                </StackPanel>

            </Grid>

            <Border
                Grid.Row="2"
                Padding="28"
                Background="{DynamicResource SurfaceOverlayBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="立即截图" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="15"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="点击一次后进入截图层，不再提前选择模式，所有操作都在鼠标交互里完成。"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Row="2"
                        Padding="18"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                        <UniformGrid Columns="2" Rows="2">
                            <Border
                                Margin="0,0,10,10"
                                Padding="14"
                                Background="{DynamicResource FeatureWindowBackgroundBrush}"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource FeatureWindowForegroundBrush}"
                                        Text="窗口" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{DynamicResource FeatureWindowDescriptionBrush}"
                                        Text="鼠标悬停到窗口上时显示边框，单击立即截图。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="10,0,0,10"
                                Padding="14"
                                Background="{DynamicResource FeatureRegionBackgroundBrush}"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource FeatureRegionForegroundBrush}"
                                        Text="矩形" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{DynamicResource FeatureRegionDescriptionBrush}"
                                        Text="按住鼠标左键拖动，松开后按所选区域截图。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="0,10,10,0"
                                Padding="14"
                                Background="{DynamicResource FeatureMonitorBackgroundBrush}"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource FeatureMonitorForegroundBrush}"
                                        Text="当前屏幕" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{DynamicResource FeatureMonitorDescriptionBrush}"
                                        Text="按 Space 直接截取鼠标所在显示器。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="10,10,0,0"
                                Padding="14"
                                Background="{DynamicResource FeatureExitBackgroundBrush}"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource FeatureExitForegroundBrush}"
                                        Text="退出" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{DynamicResource FeatureExitDescriptionBrush}"
                                        Text="Esc 或鼠标右键都可以取消本次截图。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>

                    <Button
                        Grid.Row="4"
                        Width="220"
                        Height="56"
                        HorizontalAlignment="Left"
                        BorderThickness="0"
                        Command="{Binding StartCaptureCommand}"
                        FontSize="18"
                        FontWeight="SemiBold">
                        <TextBlock Text="立即截图" />
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>