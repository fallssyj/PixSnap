<Window
    x:Class="PixSnap.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PixSnap"
    Width="760"
    Height="600"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FFF4F7FB" />
                <GradientStop Offset="0.55" Color="#FFE7EEF8" />
                <GradientStop Offset="1" Color="#FFDCE8F6" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="30"
                        FontWeight="Bold"
                        Foreground="#FF13233A"
                        Text="PixSnap" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="15"
                        Foreground="#FF4A607B"
                        Text="进入一次截图界面，用鼠标直接决定截图模式。" />
                </StackPanel>

            </Grid>

            <Border
                Grid.Row="2"
                Padding="28"
                Background="#CCFFFFFF"
                BorderBrush="#FFD8E3F0"
                BorderThickness="1"
                CornerRadius="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>


                    <Border
                        Grid.Row="2"
                        Padding="18"
                        Background="#FFF8FBFF"
                        BorderBrush="#FFE0E8F3"
                        BorderThickness="1"
                        CornerRadius="22">
                        <UniformGrid Columns="2" Rows="2">
                            <Border
                                Margin="0,0,10,10"
                                Padding="14"
                                Background="#FFFDF4DD"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="#FF624A00"
                                        Text="窗口" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="#FF7A6130"
                                        Text="鼠标悬停到窗口上时显示边框，单击立即截图。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="10,0,0,10"
                                Padding="14"
                                Background="#FFEAF5FF"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="#FF0B5CAD"
                                        Text="矩形" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="#FF466B93"
                                        Text="按住鼠标左键拖动，松开后按所选区域截图。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="0,10,10,0"
                                Padding="14"
                                Background="#FFEEF8F1"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="#FF166534"
                                        Text="当前屏幕" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="#FF3F6C53"
                                        Text="按 Space 直接截取鼠标所在显示器。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="10,10,0,0"
                                Padding="14"
                                Background="#FFFCEEEE"
                                CornerRadius="18">
                                <StackPanel>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="#FF991B1B"
                                        Text="退出" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="#FF7F3B3B"
                                        Text="Esc 或鼠标右键都可以取消本次截图。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>

                    <Button
                        Grid.Row="4"
                        Width="220"
                        Height="56"
                        HorizontalAlignment="Left"
                        Background="#FF0F766E"
                        BorderThickness="0"
                        Command="{Binding StartCaptureCommand}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="White">
                        <TextBlock Text="立即截图" />
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>