<Window
    x:Class="PixSnap.Views.RecordingControlWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:PixSnap.Behaviors"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="PixSnap 录制中"
    Width="270"
    Height="52"
    AllowsTransparency="True"
    Background="Transparent"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Border
        Padding="14,8"
        behaviors:WindowDragBehavior.IsEnabled="True"
        Background="{DynamicResource OverlayFooterBackgroundBrush}"
        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
        BorderThickness="1"
        CornerRadius="12">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Ellipse
                Width="12"
                Height="12"
                Margin="0,0,8,0"
                Fill="{Binding RecordingDotFill}">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDotAnimating}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Name="BlinkStoryboard">
                                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="1"
                                                To="0.3"
                                                Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="BlinkStoryboard" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <TextBlock
                MinWidth="56"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="{Binding TimerText}" />

            <ui:FontIcon
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="{DynamicResource OverlayWarningForegroundBrush}"
                Icon="{x:Static ui:SegoeFluentIcons.StatusWarning}"
                ToolTip="音频采集失败，录制将无声音"
                Visibility="{Binding ShowAudioWarning, Converter={StaticResource BoolToVisibility}}" />

            <Button
                Margin="12,0,0,0"
                Padding="10,3"
                Command="{Binding TogglePauseCommand}"
                Content="{Binding PauseButtonText}"
                Style="{StaticResource PixSnapButtonStyle}" />

            <Button
                Margin="6,0,0,0"
                Padding="10,3"
                Command="{Binding StopCommand}"
                Content="停止"
                Style="{StaticResource PixSnapAccentButtonStyle}" />
        </StackPanel>
    </Border>
</Window>
