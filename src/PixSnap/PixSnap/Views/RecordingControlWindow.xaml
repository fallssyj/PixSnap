<Window
    x:Class="PixSnap.Views.RecordingControlWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PixSnap 录制中"
    Width="270"
    Height="52"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Border
        Padding="14,8"
        Background="{DynamicResource OverlayFooterBackgroundBrush}"
        BorderBrush="{DynamicResource BorderSubtleBrush}"
        BorderThickness="1"
        CornerRadius="12"
        MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <!--  录制指示器  -->
            <Ellipse
                x:Name="RecordingDot"
                Width="12"
                Height="12"
                Margin="0,0,8,0"
                Fill="#E53935" />
            <!--  计时器  -->
            <TextBlock
                x:Name="TimerText"
                MinWidth="56"
                VerticalAlignment="Center"
                FontSize="16"
                Text="00:00" />
            <!--  音频警告指示器  -->
            <TextBlock
                x:Name="AudioWarningIcon"
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                Cursor="Hand"
                FontFamily="{StaticResource SegoeFluent}"
                FontSize="14"
                Foreground="#FFA500"
                Text="&#xEA85;"
                ToolTip="音频采集失败，录制将无声音"
                Visibility="Collapsed" />
            <!--  暂停 / 继续按钮  -->
            <Button
                x:Name="PauseButton"
                Margin="12,0,0,0"
                Padding="10,3"
                Click="PauseButton_Click"
                Content="暂停"
                Cursor="Hand" />
            <!--  停止按钮  -->
            <Button
                x:Name="StopButton"
                Margin="6,0,0,0"
                Padding="10,3"
                Click="StopButton_Click"
                Content="停止"
                Cursor="Hand" />
        </StackPanel>
    </Border>
</Window>
