<mica:MicaWindow
    x:Class="PixSnap.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
    Title="{StaticResource S_Settings_Title}"
    Width="420"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="-1"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border
        Background="{DynamicResource AppBackgroundBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock
                    Margin="18,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Opacity="0.6"
                    Text="{StaticResource S_Settings_Title}" />
                <Button
                    Width="44"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource CloseIconButton}">
                    <TextBlock
                        FontFamily="{StaticResource SegoeFluent}"
                        FontSize="10"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        Text="{StaticResource Glyph_Close}" />
                </Button>
            </Grid>

            <!--  分隔线  -->
            <Border
                Grid.Row="0"
                Height="1"
                VerticalAlignment="Bottom"
                Background="{DynamicResource BorderBrush}" />

            <!--  内容区  -->
            <StackPanel Grid.Row="1" Margin="{DynamicResource DialogContentPadding}">

                <!--  ── 系统 ──────────────────────────────────────────────────  -->
                <TextBlock
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="11"
                    Opacity="0.6"
                    Text="{StaticResource S_Settings_System}" />

                <!--  开机启动  -->
                <Border
                    Margin="0,8,0,0"
                    Padding="16,14"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontFamily="{StaticResource MiSansRegular}"
                                FontSize="13"
                                Text="{StaticResource S_Settings_AutoStart}" />
                            <TextBlock
                                Margin="0,3,0,0"
                                FontFamily="{StaticResource MiSansRegular}"
                                FontSize="11"
                                Opacity="0.6"
                                Text="{StaticResource S_Settings_AutoStartDesc}" />
                        </StackPanel>

                        <!--  开关控件  -->
                        <ToggleButton
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            IsChecked="{Binding IsStartupEnabled}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border
                                                    x:Name="Track"
                                                    Width="40"
                                                    Height="22"
                                                    Background="#3E3E3E"
                                                    CornerRadius="11">
                                                    <Ellipse
                                                        x:Name="Thumb"
                                                        Width="16"
                                                        Height="16"
                                                        Margin="3,0,0,0"
                                                        HorizontalAlignment="Left"
                                                        Fill="White" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Track" Property="Opacity" Value="0.85" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Track" Property="Opacity" Value="0.7" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </Grid>
                </Border>

                <!--  ── 快捷键 ──────────────────────────────────────────────  -->
                <TextBlock
                    Margin="0,20,0,0"
                    FontFamily="{StaticResource MiSansRegular}"
                    FontSize="11"
                    Opacity="0.6"
                    Text="{StaticResource S_Settings_Hotkey}" />

                <Border
                    Margin="0,8,0,0"
                    Padding="16,14"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource MiSansRegular}"
                            FontSize="13"
                            Text="{StaticResource S_Settings_HotkeyCapture}" />
                        <TextBlock
                            Margin="0,3,0,0"
                            FontFamily="{StaticResource MiSansRegular}"
                            FontSize="11"
                            Opacity="0.6"
                            Text="{StaticResource S_Settings_HotkeyHint}" />

                        <!--  快捷键输入行  -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  快捷键显示/录制框  -->
                            <TextBox
                                x:Name="HotkeyInputBox"
                                Grid.Column="0"
                                Padding="12,8"
                                Cursor="Hand"
                                FontSize="13"
                                GotFocus="HotkeyInputBox_GotFocus"
                                IsReadOnly="True"
                                LostFocus="HotkeyInputBox_LostFocus"
                                PreviewKeyDown="HotkeyInputBox_PreviewKeyDown"
                                Text="{Binding HotkeyDisplayText, Mode=OneWay}" />

                            <!--  清除按钮  -->
                            <Button
                                Grid.Column="1"
                                Height="38"
                                Margin="8,0,0,0"
                                Padding="14,0"
                                Command="{Binding ClearHotkeyCommand}"
                                Content="{StaticResource S_Common_Clear}"
                                FontSize="12" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  ── 操作按钮 ──────────────────────────────────────────────  -->
                <StackPanel
                    Margin="0,22,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="80"
                        Height="38"
                        Command="{Binding CancelCommand}"
                        Content="{StaticResource S_Common_Cancel}" />

                    <Button
                        Width="80"
                        Height="38"
                        Margin="8,0,0,0"
                        Command="{Binding SaveCommand}"
                        Content="{StaticResource S_Common_Save}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="#111111" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</mica:MicaWindow>
