<Window
    x:Class="PixSnap.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:PixSnap.Behaviors"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="设置"
    Width="560"
    Height="720"
    MinWidth="500"
    MinHeight="560"
    ResizeMode="CanResize"
    SizeToContent="Manual"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    ui:TitleBar.Height="36">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,20,28,12">
            <controls:PageHeader Subtitle="自定义你的 PixSnap" Title="设置">
                <controls:PageHeader.IconContent>
                    <ui:FontIcon
                        FontSize="18"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        Icon="{x:Static ui:SegoeFluentIcons.Settings}" />
                </controls:PageHeader.IconContent>
            </controls:PageHeader>
        </Border>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="28,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Row="2"
            Padding="28,12,28,8"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Margin="4,0,0,8" Style="{StaticResource SectionHeaderStyle}" Text="常规" />
                <Border Style="{StaticResource GroupCardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource CardRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" MinWidth="160" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:FontIcon
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource RowIconStyle}"
                                    Icon="{x:Static ui:SegoeFluentIcons.PowerButton}" />
                                <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource RowTitleStyle}" Text="开机启动" />
                                    <TextBlock Style="{StaticResource RowDescStyle}" Text="登录后自动在后台启动" />
                                </StackPanel>
                                <ui:ToggleSwitch
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    IsOn="{Binding IsStartupEnabled}"
                                    Style="{StaticResource SettingsToggleSwitchStyle}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardSeparatorStyle}" />

                        <Border Style="{StaticResource CardRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" MinWidth="160" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:FontIcon
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource RowIconStyle}"
                                    Icon="{x:Static ui:SegoeFluentIcons.Color}" />
                                <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource RowTitleStyle}" Text="主题" />
                                    <TextBlock Style="{StaticResource RowDescStyle}" Text="选择应用的外观主题" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="2"
                                    MinWidth="96"
                                    VerticalAlignment="Center"
                                    SelectedIndex="{Binding SelectedThemeIndex}">
                                    <ComboBoxItem Content="自动" />
                                    <ComboBoxItem Content="深色" />
                                    <ComboBoxItem Content="浅色" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="快捷键" />
                <Border Style="{StaticResource GroupCardStyle}">
                    <Border Style="{StaticResource CardRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ui:FontIcon
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                Margin="0,2,0,0"
                                Style="{StaticResource RowIconStyle}"
                                Icon="{x:Static ui:SegoeFluentIcons.KeyboardClassic}" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource RowTitleStyle}" Text="截图/录制快捷键" />
                                <TextBlock Style="{StaticResource RowDescStyle}" Text="点击输入框后按下组合键，Esc 取消" />
                            </StackPanel>
                            <Grid Grid.Row="1" Grid.Column="1" Margin="12,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Style="{StaticResource SettingsPathTextBoxStyle}"
                                    behaviors:HotkeyRecordBehavior.IsEnabled="True"
                                    Cursor="Hand"
                                    IsReadOnly="True"
                                    Text="{Binding HotkeyDisplayText, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Command="{Binding ClearHotkeyCommand}"
                                    Content="清除"
                                    Style="{StaticResource SettingsActionButtonStyle}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Border>

                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="存储" />
                <Border Style="{StaticResource GroupCardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource CardRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:FontIcon
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.RowSpan="2"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"
                                    Style="{StaticResource RowIconStyle}"
                                    Icon="{x:Static ui:SegoeFluentIcons.Save}" />
                                <Grid Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource RowTitleStyle}" Text="自动保存" />
                                        <TextBlock Style="{StaticResource RowDescStyle}" Text="截图后自动保存到指定目录" />
                                    </StackPanel>
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        IsOn="{Binding IsAutoSaveEnabled}"
                                        Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                                <Grid Grid.Row="1" Grid.Column="1" Margin="12,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsPathTextBoxStyle}"
                                        IsReadOnly="True"
                                        Text="{Binding SaveDirectory, Mode=OneWay}" />
                                    <Button
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseSaveDirectoryCommand}"
                                        Content="浏览"
                                        Style="{StaticResource SettingsActionButtonStyle}" />
                                    <Button
                                        Grid.Column="2"
                                        Margin="4,0,0,0"
                                        Command="{Binding OpenSaveDirectoryCommand}"
                                        Style="{StaticResource SettingsIconButtonStyle}"
                                        ToolTip="打开目录">
                                        <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.Folder}" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardSeparatorStyle}" />

                        <Border Style="{StaticResource CardRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:FontIcon
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.RowSpan="2"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"
                                    Style="{StaticResource RowIconStyle}"
                                    Icon="{x:Static ui:SegoeFluentIcons.Video}" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Style="{StaticResource RowTitleStyle}" Text="录屏临时目录" />
                                    <TextBlock Style="{StaticResource RowDescStyle}" Text="录制文件的临时存放位置" />
                                </StackPanel>
                                <Grid Grid.Row="1" Grid.Column="1" Margin="12,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsPathTextBoxStyle}"
                                        IsReadOnly="True"
                                        Text="{Binding RecordingTempDirectory, Mode=OneWay}" />
                                    <Button
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseRecordingTempDirectoryCommand}"
                                        Content="浏览"
                                        Style="{StaticResource SettingsActionButtonStyle}" />
                                    <Button
                                        Grid.Column="2"
                                        Margin="4,0,0,0"
                                        Command="{Binding OpenRecordingTempDirectoryCommand}"
                                        Style="{StaticResource SettingsIconButtonStyle}"
                                        ToolTip="打开目录">
                                        <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.Folder}" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            Padding="28,14,28,20"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    MinWidth="88"
                    Height="36"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource PixSnapButtonStyle}" />
                <Button
                    MinWidth="88"
                    Height="36"
                    Margin="8,0,0,0"
                    Command="{Binding SaveCommand}"
                    Content="保存"
                    Style="{StaticResource PixSnapAccentButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
