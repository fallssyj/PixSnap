<Window
    x:Class="PixSnap.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:PixSnap.Behaviors"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="设置"
    Width="580"
    Height="720"
    MinWidth="520"
    MinHeight="560"
    ResizeMode="CanResize"
    SizeToContent="Manual"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:TitleBar.Height="36"
    ui:TitleBar.MaximizeButtonAvailability="Collapsed"
    ui:TitleBar.MinimizeButtonAvailability="Collapsed"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="32,24,32,8">
            <controls:PageHeader Subtitle="自定义截图、录屏与 AI 相关选项" Title="设置">
                <controls:PageHeader.IconContent>
                    <ui:FontIcon
                        FontSize="18"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        Icon="{x:Static ui:SegoeFluentIcons.Settings}" />
                </controls:PageHeader.IconContent>
            </controls:PageHeader>
        </Border>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="32,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Row="2"
            Padding="32,16,32,12"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <ikw:SimpleStackPanel MaxWidth="640" Spacing="4">
                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="常规" />

                    <ui:SettingsCard
                        Description="登录 Windows 后自动在后台启动 PixSnap"
                        Header="开机启动">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.PowerButton}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ui:ToggleSwitch
                            IsOn="{Binding IsStartupEnabled}"
                            Style="{StaticResource SettingsToggleSwitchStyle}" />
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="跟随系统或固定为浅色 / 深色外观"
                        Header="主题">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Color}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox MinWidth="96" SelectedIndex="{Binding SelectedThemeIndex}">
                            <ComboBoxItem Content="自动" />
                            <ComboBoxItem Content="深色" />
                            <ComboBoxItem Content="浅色" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="AI" />

                    <ui:SettingsCard
                        Description="选择 OCR、去背景、超分、AI 擦除等功能的推理设备"
                        Header="GPU 加速">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Robot}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox
                            MinWidth="220"
                            MaxWidth="300"
                            DisplayMemberPath="DisplayName"
                            IsEnabled="{Binding IsGpuListReady}"
                            ItemsSource="{Binding GpuDevices}"
                            SelectedItem="{Binding SelectedGpuDevice}" />
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="Mobile 速度更快，Server 准确率更高（需下载模型）"
                        Header="文字识别模型">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Font}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox MinWidth="160" SelectedIndex="{Binding SelectedOcrModelIndex}">
                            <ComboBoxItem Content="Mobile（推荐）" />
                            <ComboBoxItem Content="Server（高精度）" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="RMBG-1.4 / RMBG-2.0 / BiRefNet，在模型管理中下载"
                        Header="抠图模型">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Color}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox MinWidth="200" SelectedIndex="{Binding SelectedMattingModelIndex}">
                            <ComboBoxItem Content="RMBG-1.4（默认）" />
                            <ComboBoxItem Content="RMBG-2.0" />
                            <ComboBoxItem Content="BiRefNet FP16" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="2× 更快，4× 更清晰"
                        Header="超分辨率模型">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ZoomIn}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox MinWidth="160" SelectedIndex="{Binding SelectedSuperResolutionModelIndex}">
                            <ComboBoxItem Content="4×（高质量）" />
                            <ComboBoxItem Content="2×（更快）" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="MobileSAM 支持点选；FastSAM 为整图分割"
                        Header="图像分割模型">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Glyph="&#xE7B3;" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox MinWidth="160" SelectedIndex="{Binding SelectedSegmentationModelIndex}">
                            <ComboBoxItem Content="MobileSAM" />
                            <ComboBoxItem Content="FastSAM-S" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="截图描述与问答（模型较大，按需下载）"
                        Header="视觉理解模型">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Robot}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox MinWidth="180" SelectedIndex="{Binding SelectedVisionModelIndex}">
                            <ComboBoxItem Content="Florence-2" />
                            <ComboBoxItem Content="Moondream2" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        Description="OCR、抠图、超分、分割、读图等全部 ONNX 模型"
                        Header="模型管理">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Download}" />
                        </ui:SettingsCard.HeaderIcon>
                        <Button
                            MinWidth="120"
                            Command="{Binding OpenAiModelsCommand}"
                            Content="查看与下载"
                            Style="{StaticResource SettingsActionButtonStyle}" />
                    </ui:SettingsCard>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="快捷键" />

                    <ui:SettingsCard
                        ContentAlignment="Left"
                        Description="点击输入框后按下组合键，Esc 取消录制"
                        Header="截图 / 录制">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.KeyboardClassic}" />
                        </ui:SettingsCard.HeaderIcon>
                        <Grid MinWidth="280">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="140" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Style="{StaticResource SettingsPathTextBoxStyle}"
                                behaviors:HotkeyRecordBehavior.IsEnabled="True"
                                Cursor="Hand"
                                IsReadOnly="True"
                                Text="{Binding HotkeyDisplayText, Mode=OneWay}" />
                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Command="{Binding ClearHotkeyCommand}"
                                Content="清除"
                                Style="{StaticResource SettingsActionButtonStyle}" />
                        </Grid>
                    </ui:SettingsCard>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="存储" />

                    <ui:SettingsCard
                        Description="截图完成后自动保存到指定目录"
                        Header="自动保存">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Save}" />
                        </ui:SettingsCard.HeaderIcon>
                        <ui:ToggleSwitch
                            IsOn="{Binding IsAutoSaveEnabled}"
                            Style="{StaticResource SettingsToggleSwitchStyle}" />
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        ContentAlignment="Left"
                        Description="截图文件的默认保存位置"
                        Header="保存目录">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Folder}" />
                        </ui:SettingsCard.HeaderIcon>
                        <Grid MinWidth="280">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="140" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Style="{StaticResource SettingsPathTextBoxStyle}"
                                IsReadOnly="True"
                                Text="{Binding SaveDirectory, Mode=OneWay}" />
                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Command="{Binding BrowseSaveDirectoryCommand}"
                                Content="浏览"
                                Style="{StaticResource SettingsActionButtonStyle}" />
                            <Button
                                Grid.Column="2"
                                Margin="4,0,0,0"
                                Command="{Binding OpenSaveDirectoryCommand}"
                                Style="{StaticResource SettingsIconButtonStyle}"
                                ToolTip="在资源管理器中打开">
                                <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.FolderOpen}" />
                            </Button>
                        </Grid>
                    </ui:SettingsCard>

                    <ui:SettingsCard
                        ContentAlignment="Left"
                        Description="录制过程中临时文件的存放位置"
                        Header="录屏临时目录">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Video}" />
                        </ui:SettingsCard.HeaderIcon>
                        <Grid MinWidth="280">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="140" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Style="{StaticResource SettingsPathTextBoxStyle}"
                                IsReadOnly="True"
                                Text="{Binding RecordingTempDirectory, Mode=OneWay}" />
                            <Button
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Command="{Binding BrowseRecordingTempDirectoryCommand}"
                                Content="浏览"
                                Style="{StaticResource SettingsActionButtonStyle}" />
                            <Button
                                Grid.Column="2"
                                Margin="4,0,0,0"
                                Command="{Binding OpenRecordingTempDirectoryCommand}"
                                Style="{StaticResource SettingsIconButtonStyle}"
                                ToolTip="在资源管理器中打开">
                                <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.FolderOpen}" />
                            </Button>
                        </Grid>
                    </ui:SettingsCard>
                </ikw:SimpleStackPanel>
            </Grid>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            Padding="32,14,32,22"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    MinWidth="88"
                    Height="36"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource PixSnapButtonStyle}" />
                <Button
                    MinWidth="88"
                    Height="36"
                    Margin="8,0,0,0"
                    Command="{Binding SaveCommand}"
                    Content="保存"
                    Style="{StaticResource PixSnapAccentButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
