<Window
    x:Class="PixSnap.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:PixSnap.Behaviors"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="设置"
    Width="600"
    Height="760"
    MinWidth="540"
    MinHeight="600"
    ResizeMode="CanResize"
    SizeToContent="Manual"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:TitleBar.Height="36"
    ui:TitleBar.MaximizeButtonAvailability="Collapsed"
    ui:TitleBar.MinimizeButtonAvailability="Collapsed"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="32,24,32,8">
            <controls:PageHeader Subtitle="自定义截图、录屏与 AI 相关选项" Title="设置">
                <controls:PageHeader.IconContent>
                    <ui:FontIcon
                        FontSize="18"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        Icon="{x:Static ui:SegoeFluentIcons.Settings}" />
                </controls:PageHeader.IconContent>
            </controls:PageHeader>
        </Border>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="32,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Row="2"
            Padding="32,16,32,12"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <ikw:SimpleStackPanel MaxWidth="520" Spacing="0">
                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="常规" />

                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <ikw:SimpleStackPanel Spacing="0">
                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="开机启动" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="登录 Windows 后自动在后台运行" />
                                    </StackPanel>
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        IsOn="{Binding IsStartupEnabled}"
                                        Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />
                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="主题" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="跟随系统或固定浅色 / 深色" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        SelectedIndex="{Binding SelectedThemeIndex}"
                                        Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="自动" />
                                        <ComboBoxItem Content="深色" />
                                        <ComboBoxItem Content="浅色" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />
                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="双击托盘图标" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="双击任务栏右下角图标时的默认操作" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        SelectedIndex="{Binding SelectedTrayDoubleClickActionIndex}"
                                        Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="截图" />
                                        <ComboBoxItem Content="打开预览窗口" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </ikw:SimpleStackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="AI 推理" />

                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <ikw:SimpleStackPanel Spacing="0">
                            <TextBlock Style="{StaticResource SettingsSectionTitleInCardStyle}" Text="设备与模型" />

                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="GPU 加速" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="OCR、抠图、超分等功能的推理设备" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        DisplayMemberPath="DisplayName"
                                        IsEnabled="{Binding IsGpuListReady}"
                                        ItemsSource="{Binding GpuDevices}"
                                        SelectedItem="{Binding SelectedGpuDevice}"
                                        Style="{StaticResource SettingsComboBoxStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />

                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="文字识别" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="Mobile 更快，Server 更准" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        SelectedIndex="{Binding SelectedOcrModelIndex}"
                                        Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="Mobile（推荐）" />
                                        <ComboBoxItem Content="Server（高精度）" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />

                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="抠图" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="去除背景所用模型" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        SelectedIndex="{Binding SelectedMattingModelIndex}"
                                        Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="RMBG-1.4" />
                                        <ComboBoxItem Content="BiRefNet" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />

                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="超分辨率" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="2× 与 4× 速度相当；4× 放大倍数更高" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="1"
                                        SelectedIndex="{Binding SelectedSuperResolutionModelIndex}"
                                        Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="4×（高质量）" />
                                        <ComboBoxItem Content="2×" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />

                            <Border Padding="12,10">
                                <Button
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenAiModelsCommand}"
                                    Content="管理 ONNX 模型下载…"
                                    Style="{StaticResource SettingsActionButtonStyle}" />
                            </Border>
                        </ikw:SimpleStackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="快捷键" />

                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <Border Style="{StaticResource SettingsFieldRowStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="截图 / 录制" />
                                <TextBlock
                                    Margin="0,2,0,10"
                                    Style="{StaticResource SettingsRowDescStyle}"
                                    Text="点击输入框后按下组合键，Esc 取消" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Style="{StaticResource SettingsPathTextBoxStyle}"
                                        behaviors:HotkeyRecordBehavior.IsEnabled="True"
                                        Cursor="Hand"
                                        IsReadOnly="True"
                                        Text="{Binding HotkeyDisplayText, Mode=OneWay}" />
                                    <Button
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Command="{Binding ClearHotkeyCommand}"
                                        Content="清除"
                                        Style="{StaticResource SettingsActionButtonStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsSectionHeaderStyle}" Text="存储" />

                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <ikw:SimpleStackPanel Spacing="0">
                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="自动保存" />
                                        <TextBlock Style="{StaticResource SettingsRowDescStyle}" Text="截图后保存到指定目录" />
                                    </StackPanel>
                                    <ui:ToggleSwitch
                                        Grid.Column="1"
                                        IsOn="{Binding IsAutoSaveEnabled}"
                                        Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />

                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="保存目录" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Style="{StaticResource SettingsPathTextBoxStyle}"
                                            IsReadOnly="True"
                                            Text="{Binding SaveDirectory, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseSaveDirectoryCommand}"
                                            Content="浏览"
                                            Style="{StaticResource SettingsActionButtonStyle}" />
                                        <Button
                                            Grid.Column="2"
                                            Margin="4,0,0,0"
                                            Command="{Binding OpenSaveDirectoryCommand}"
                                            Style="{StaticResource SettingsIconButtonStyle}"
                                            ToolTip="在资源管理器中打开">
                                            <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.FolderOpen}" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsFieldSeparatorStyle}" />

                            <Border Style="{StaticResource SettingsFieldRowStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SettingsRowTitleStyle}" Text="录屏临时目录" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Style="{StaticResource SettingsPathTextBoxStyle}"
                                            IsReadOnly="True"
                                            Text="{Binding RecordingTempDirectory, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseRecordingTempDirectoryCommand}"
                                            Content="浏览"
                                            Style="{StaticResource SettingsActionButtonStyle}" />
                                        <Button
                                            Grid.Column="2"
                                            Margin="4,0,0,0"
                                            Command="{Binding OpenRecordingTempDirectoryCommand}"
                                            Style="{StaticResource SettingsIconButtonStyle}"
                                            ToolTip="在资源管理器中打开">
                                            <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.FolderOpen}" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </ikw:SimpleStackPanel>
                    </Border>
                </ikw:SimpleStackPanel>
            </Grid>
        </ScrollViewer>

        <Border
            Grid.Row="3"
            Padding="32,14,32,22"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    MinWidth="88"
                    Height="36"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource PixSnapButtonStyle}" />
                <Button
                    MinWidth="88"
                    Height="36"
                    Margin="8,0,0,0"
                    Command="{Binding SaveCommand}"
                    Content="保存"
                    Style="{StaticResource PixSnapAccentButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
