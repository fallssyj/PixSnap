<Window
    x:Class="PixSnap.Views.NotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Width="320"
    Height="150"
    AllowsTransparency="True"
    Background="Transparent"
    Cursor="Hand"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    TextOptions.TextFormattingMode="Display"
    Topmost="True"
    UseLayoutRounding="True"
    WindowStyle="None">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation
                Storyboard.TargetName="RootBorder"
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="SlideTransform"
                Storyboard.TargetProperty="Y"
                From="20"
                To="0"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation
                Storyboard.TargetName="RootBorder"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="SlideTransform"
                Storyboard.TargetProperty="Y"
                To="20"
                Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border
        x:Name="RootBorder"
        Margin="8"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        CornerRadius="8"
        Opacity="0">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="16"
                Direction="270"
                Opacity="0.35"
                ShadowDepth="4"
                Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Border.RenderTransform>

        <Grid Margin="12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题行  -->
            <DockPanel Grid.Row="0">
                <ui:FontIcon
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Icon="{x:Static ui:SegoeFluentIcons.Copy}" />
                <TextBlock
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="截图已复制到剪贴板" />
                <Button
                    Width="22"
                    Height="22"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding DismissCommand}"
                    DockPanel.Dock="Right"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    ToolTip="关闭">
                    <ui:FontIcon FontSize="10" Icon="{x:Static ui:SegoeFluentIcons.ChromeClose}" />
                </Button>
            </DockPanel>

            <!--  内容区域  -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  缩略图  -->
                <Border
                    Grid.Column="0"
                    Width="100"
                    CornerRadius="4">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="Uniform" />
                    </Border.Background>
                </Border>

                <!--  信息  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{Binding ImageSizeText}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="点击打开编辑" />
                </StackPanel>
            </Grid>

            <!--  倒计时进度条  -->
            <ProgressBar
                Grid.Row="2"
                Height="5"
                Margin="0,8,0,0"
                Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}"
                BorderThickness="0"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                Maximum="1"
                Value="{Binding RemainingProgress, Mode=OneWay}" />
        </Grid>
    </Border>
</Window>
