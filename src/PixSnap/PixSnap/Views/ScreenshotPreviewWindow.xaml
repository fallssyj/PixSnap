                            Foreground="{DynamicResource TextPrimaryBrush}">
                            <TextBlock Text="复制到剪贴板" />
                        </Button>

                        <Button
                            Height="44"
                            Margin="0,12,0,0"
                            Background="{DynamicResource PreviewGhostButtonBackgroundBrush}"
                            BorderBrush="{DynamicResource PreviewGhostButtonBorderBrush}"
