<Window
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    Title="{StaticResource S_Preview_Title}"
    Width="1040"
    Height="760"
    MinWidth="1000"
    MinHeight="520"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>


    <Border
        x:Name="RootBorder"
        Background="{DynamicResource AppBackgroundBrush}"
        CornerRadius="10"
        MouseLeftButtonDown="OnWindowDragMove"
        Style="{StaticResource RoundedWindowBorderStyle}">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  顶部控制  -->
                <Grid Grid.Row="0">
                    <StackPanel
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button
                            Width="70"
                            Height="35"
                            Margin="10,5,0,5"
                            Command="{Binding OpenFileCommand}"
                            ToolTip="{StaticResource S_Preview_OpenFile}">
                            <Button.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Direction="315"
                                    Opacity="0.3"
                                    ShadowDepth="5"
                                    Color="Black" />
                            </Button.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="{StaticResource SegoeMDL2}"
                                    FontSize="14"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Text="{StaticResource Glyph_OpenImage}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Text="{StaticResource S_Common_Open}" />
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="ButtonRoot"
                                                    Background="{DynamicResource ButtonPrimaryBackgroundBrush}"
                                                    CornerRadius="5"
                                                    SnapsToDevicePixels="True">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        RecognizesAccessKey="True" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.96" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.88" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Margin="20,0,2,0"
                            Command="{Binding SaveToFileCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Common_Save}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Save}" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding UndoCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_Undo}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Undo}" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding RedoCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_Redo}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Redo}" />
                        </Button>
                        <!--  分隔符  -->
                        <Border
                            Width="1"
                            Height="18"
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource BorderBrush}" />
                        <Button
                            Margin="2,0"
                            Command="{Binding RotateImageCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_Rotate}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Rotate}" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding CopyToClipboardCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_CopyToClipboard}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Copy}" />
                        </Button>
                        <!--  分隔符  -->
                        <Border
                            Width="1"
                            Height="18"
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource BorderBrush}" />
                        <Button
                            Margin="2,0"
                            Command="{Binding ToggleCropCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_Crop}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Crop}" />
                        </Button>

                        <Button
                            Margin="2,0"
                            Command="{Binding ToggleRoundCornerCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_RoundCorner}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_RoundCorner}" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding ToggleEraserCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_AiErase}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Eraser}" />
                        </Button>
                        <!--  分隔符  -->
                        <Border
                            Width="1"
                            Height="18"
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource BorderBrush}" />
                        <Button
                            Margin="2,0"
                            Command="{Binding RecaptureCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="{StaticResource S_Preview_Recapture}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Recapture}" />
                        </Button>
                        <Border
                            Margin="30,0"
                            Height="30"
                            Padding="10,5"
                            Background="{DynamicResource AppBackgroundBrush}"
                            BorderBrush="{DynamicResource AppGradientEndBrush}"
                            BorderThickness="0.8"
                            CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Direction="315"
                                    Opacity="0.3"
                                    ShadowDepth="5"
                                    Color="Black" />
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    MaxWidth="420"
                                    Margin="5,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Text="{Binding CaptureTitleDisplay}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,0,0"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource IconButton}"
                            ToolTip="{StaticResource S_Common_Settings}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="10"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Settings}" />
                        </Button>
                        <Button
                            Margin="0,0,0,0"
                            Command="{Binding MinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource IconButton}"
                            ToolTip="{StaticResource S_Preview_Minimize}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="10"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Minimize}" />
                        </Button>
                        <Button
                            Command="{Binding MaximizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            FontFamily="{StaticResource SegoeMDL2}"
                            FontSize="10"
                            Foreground="{DynamicResource TextPrimaryBrush}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource IconButton}" TargetType="Button">
                                    <Setter Property="ToolTip" Value="{StaticResource S_Preview_Maximize}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                                            <Setter Property="ToolTip" Value="{StaticResource S_Preview_Restore}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="10"
                                Foreground="{DynamicResource TextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{StaticResource Glyph_Maximize}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                                                <Setter Property="Text" Value="{StaticResource Glyph_Restore}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource CloseIconButton}"
                            ToolTip="{StaticResource S_Common_Close}">
                            <TextBlock
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="10"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Text="{StaticResource Glyph_Close}" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!--  预览区域  -->
                <Grid
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="{StaticResource TransparencyCheckerBrush}">
                    <Border PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
                        <Grid
                            x:Name="PreviewViewport"
                            ClipToBounds="True"
                            MouseRightButtonUp="PreviewViewport_MouseRightButtonUp"
                            SizeChanged="PreviewViewport_SizeChanged">
                            <Grid x:Name="FitPreviewHost">

                                <Image
                                    x:Name="FitPreviewImage"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="LowQuality"
                                    Source="{Binding ScreenshotImage}"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly" />
                            </Grid>

                            <ScrollViewer
                                x:Name="ActualSizeScrollViewer"
                                HorizontalScrollBarVisibility="Hidden"
                                MouseLeave="ActualSizeScrollViewer_MouseLeave"
                                PreviewMouseLeftButtonDown="ActualSizeScrollViewer_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ActualSizeScrollViewer_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                                VerticalScrollBarVisibility="Hidden"
                                Visibility="Collapsed">
                                <!--  Padding 在图片四周创建可滑动的空白区，实现拖动到边缘后还能继续拖动  -->
                                <Border Padding="200">
                                    <Image
                                        x:Name="ActualSizeImage"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="LowQuality"
                                        Source="{Binding ScreenshotImage}"
                                        Stretch="None">
                                        <Image.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </Border>
                            </ScrollViewer>

                            <!--  裁剪框覆盖层：只在裁剪模式下显示  -->
                            <controls:CropOverlayControl x:Name="CropOverlay" Visibility="Collapsed" />

                            <!--  AI 擦除涂抹覆盖层：Cursor=None 配合代码后置圆形光标指示器  -->
                            <Canvas
                                x:Name="EraserCanvas"
                                Background="Transparent"
                                Cursor="None"
                                IsHitTestVisible="False"
                                MouseEnter="EraserCanvas_MouseEnter"
                                MouseLeave="EraserCanvas_MouseLeave"
                                MouseLeftButtonDown="EraserCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="EraserCanvas_MouseLeftButtonUp"
                                MouseMove="EraserCanvas_MouseMove">
                                <!--  跟随鼠标的画刷轮廓（由代码后置动态定位和缩放）  -->
                                <Ellipse
                                    x:Name="EraserCursorIndicator"
                                    Fill="{DynamicResource AccentBrush}"
                                    IsHitTestVisible="False"
                                    Opacity="0.13"
                                    Stroke="{DynamicResource AccentBrush}"
                                    StrokeThickness="2"
                                    Visibility="Collapsed" />
                            </Canvas>
                        </Grid>
                    </Border>

                    <!--  裁剪信息拖动面板  -->
                    <Border
                        x:Name="CropPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CropPanelTranslate" />
                        </Border.RenderTransform>
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <StackPanel MinWidth="220">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="{StaticResource S_Preview_Crop}" />
                            <!--  比例预设  -->
                            <WrapPanel Margin="0,0,0,8">
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="0:0"
                                    Content="{StaticResource S_Crop_Free}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_FreeCrop}" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="1:1:1:1"
                                    Content="1:1"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_Square}" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="16:9:16:9"
                                    Content="16:9"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_Widescreen}" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="4:3:4:3"
                                    Content="4:3"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_Standard}" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="3:2:3:2"
                                    Content="3:2"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_Camera}" />
                            </WrapPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding CropPanel.AspectRatioDisplayText}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!--  X  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    ToolTip="{StaticResource S_Crop_StartX}">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_Crop_AxisX}" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  Y  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    ToolTip="{StaticResource S_Crop_StartY}">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_Crop_AxisY}" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  W  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    ToolTip="{StaticResource S_Crop_Width}">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_Crop_WidthLabel}" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  H  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    ToolTip="{StaticResource S_Crop_Height}">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_Crop_HeightLabel}" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding CropPanel.CancelCommand}"
                                    Content="{StaticResource S_Common_Cancel}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_CancelCrop}" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding CropPanel.ApplyCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="{StaticResource S_Common_Apply}"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="{StaticResource S_Crop_ApplyCrop}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  圆角信息拖动面板  -->
                    <Border
                        x:Name="RoundCornerPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="RoundCornerPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="200">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="{StaticResource S_Preview_RoundCorner}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_RoundCorner_RadiusLabel}" />
                                <TextBox
                                    Margin="5,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding RoundCornerPanel.CornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding RoundCornerPanel.CancelCommand}"
                                    Content="{StaticResource S_Common_Cancel}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_RoundCorner_Cancel}" />
                                <Button
                                    Command="{Binding RoundCornerPanel.ApplyCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="{StaticResource S_Common_Apply}"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="{StaticResource S_RoundCorner_Apply}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  AI 擦除画刷大小浮动面板  -->
                    <Border
                        x:Name="EraserFloatingPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EraserFloatingPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="200">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="{StaticResource S_Eraser_Title}" />
                            <!--  画刷大小输入  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_Eraser_BrushSize}" />
                                <TextBox
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding EraserPanel.BrushSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="px" />
                            </StackPanel>
                            <Slider
                                Margin="0,8,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="200"
                                Minimum="5"
                                SmallChange="1"
                                TickFrequency="5"
                                Value="{Binding EraserPanel.BrushSize, Mode=TwoWay}" />

                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{StaticResource S_Eraser_Feather}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="{Binding EraserPanel.EdgeFeatherStrengthText}" />
                            </StackPanel>
                            <Slider
                                Margin="0,6,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                TickFrequency="5"
                                Value="{Binding EraserPanel.EdgeFeatherStrength, Mode=TwoWay}" />

                            <!--  操作按钮  -->
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding EraserPanel.ClearStrokesCommand}"
                                    Content="{StaticResource S_Common_Clear}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Eraser_ClearPaint}" />
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding ExitEraserModeCommand}"
                                    Content="{StaticResource S_Common_Cancel}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="{StaticResource S_Eraser_CancelHint}" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding ApplyEraserCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="{StaticResource S_Common_Apply}"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="{StaticResource S_Eraser_ApplyAi}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Popup
                        x:Name="AiModulePopup"
                        AllowsTransparency="True"
                        IsOpen="{Binding IsAiPopupOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=AiModuleButton}"
                        PopupAnimation="Fade"
                        StaysOpen="False"
                        VerticalOffset="6">
                        <Border
                            MinWidth="180"
                            Padding="8"
                            Background="#E61A1A1A"
                            BorderBrush="#333"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel>
                                <Button
                                    Margin="0,0,0,6"
                                    Command="{Binding RemoveBackgroundCommand}"
                                    Content="{StaticResource S_Preview_RemoveBg}"
                                    Style="{StaticResource PanelCancelButtonStyle}" />
                                <Button
                                    Command="{Binding SuperResolutionCommand}"
                                    Content="{StaticResource S_Preview_SuperRes}"
                                    Style="{StaticResource PanelCancelButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </Popup>

                </Grid>
                <!--  控制区域  -->
                <Border
                    Grid.Row="2"
                    Padding="10"
                    Background="{DynamicResource AppGradientStartBrush}">
                    <!--  CornerRadius="0,0,10,10">  -->
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock
                                Margin="10,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{StaticResource Glyph_Resolution}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding ImageSize}" />
                            <TextBlock
                                Margin="10,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource SegoeMDL2}"
                                FontSize="14"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{StaticResource Glyph_List}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding FileSize}" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Margin="2,0"
                                Command="{Binding TogglePreviewScaleCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="{Binding PreviewScaleModeText}">
                                <Grid>
                                    <TextBlock
                                        FontFamily="{StaticResource SegoeMDL2}"
                                        FontSize="14"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{StaticResource Glyph_FitWindow}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource SegoeMDL2}"
                                        FontSize="5"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        Text="{StaticResource Glyph_OriginalSize}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                            <ComboBox
                                Margin="2,0"
                                SelectedValue="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Tag"
                                Text="{Binding ZoomCompactText, Mode=OneWay}">
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="200%" Tag="200" />
                                <ComboBoxItem Content="300%" Tag="300" />
                                <ComboBoxItem Content="400%" Tag="400" />
                                <ComboBoxItem Content="500%" Tag="500" />
                                <ComboBoxItem Content="600%" Tag="600" />
                                <ComboBoxItem Content="700%" Tag="700" />
                                <ComboBoxItem Content="800%" Tag="800" />
                            </ComboBox>

                            <Button
                                Margin="2,0"
                                Command="{Binding ZoomOutCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="{StaticResource S_Preview_ZoomOut}">
                                <TextBlock
                                    FontFamily="{StaticResource SegoeMDL2}"
                                    FontSize="14"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Text="{StaticResource Glyph_ZoomOut}" />
                            </Button>

                            <Slider
                                Margin="2,0"
                                IsSnapToTickEnabled="False"
                                LargeChange="25"
                                Maximum="800"
                                Minimum="10"
                                SmallChange="5"
                                TickFrequency="25"
                                Value="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button
                                Margin="2,0"
                                Command="{Binding ZoomInCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="{StaticResource S_Preview_ZoomIn}">
                                <TextBlock
                                    FontFamily="{StaticResource SegoeMDL2}"
                                    FontSize="14"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Text="{StaticResource Glyph_ZoomIn}" />
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>

            <!--  全窗口处理遮罩：处理期间阻断所有操作，完成或异常后自动隐藏  -->
            <Grid Panel.ZIndex="998">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnyAiProcessing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border Background="#80101010" />

                <Border
                    Margin="0,0,0,100"
                    Padding="16,12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Background="#CC1A1A1A"
                    CornerRadius="12">
                    <StackPanel MinWidth="280" Orientation="Vertical">
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="{Binding ActiveAiProgressText}" />
                        <ProgressBar
                            Height="6"
                            IsIndeterminate="{Binding IsAnyIndeterminateProcessing, Mode=OneWay}"
                            Maximum="1"
                            Minimum="0"
                            Value="{Binding ActiveAiProgress, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                x:Name="OverlayBorder"
                Panel.ZIndex="999"
                BorderBrush="{StaticResource AppGradientEndBrush}"
                BorderThickness="0.5"
                CornerRadius="10"
                IsHitTestVisible="False" />
        </Grid>


    </Border>
</Window>