<Window
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="截图预览"
    Width="1040"
    Height="760"
    MinWidth="720"
    MinHeight="520"
    PreviewKeyDown="Window_PreviewKeyDown"
    WindowStartupLocation="CenterOwner">
    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>

    <Window.Resources>
        <DrawingBrush
            x:Key="TransparencyCheckerBrush"
            Stretch="None"
            TileMode="Tile"
            Viewbox="0,0,16,16"
            ViewboxUnits="Absolute"
            Viewport="0,0,16,16"
            ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFE7EDF5">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFD8E1EC">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8" />
                                <RectangleGeometry Rect="8,8,8,8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid Background="#FFF3F6FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Border
            Margin="20"
            Background="White"
            BorderBrush="#FFD9E2EC"
            BorderThickness="1"
            CornerRadius="24"
            PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
            <Grid
                x:Name="PreviewViewport"
                Background="{StaticResource TransparencyCheckerBrush}"
                SizeChanged="PreviewViewport_SizeChanged">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="ClipToBounds" Value="True" />
                    </Style>
                </Grid.Style>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Image
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="{Binding ScreenshotImage}"
                        Stretch="Uniform"
                        StretchDirection="DownOnly" />
                </Grid>

                <ScrollViewer
                    x:Name="ActualSizeScrollViewer"
                    HorizontalScrollBarVisibility="Auto"
                    MouseLeave="ActualSizeScrollViewer_MouseLeave"
                    PreviewMouseLeftButtonDown="ActualSizeScrollViewer_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="ActualSizeScrollViewer_PreviewMouseLeftButtonUp"
                    PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                    VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>

                    <Image
                        x:Name="ActualSizeImage"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="{Binding ScreenshotImage}"
                        Stretch="None">
                        <Image.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                        </Image.LayoutTransform>
                    </Image>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Margin="0,20,20,20"
            Padding="22"
            Background="#FF0F172A"
            CornerRadius="24">
            <StackPanel>
                <TextBlock
                    FontSize="26"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="截图预览" />
                <TextBlock
                    Margin="0,10,0,0"
                    Foreground="#FFB7C3D7"
                    Text="查看、保存、复制当前截图。" />

                <Border
                    Margin="0,24,0,0"
                    Padding="16"
                    Background="#1FFFFFFF"
                    CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="#FF8FA7C4" Text="截图模式" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding CaptureMode}" />
                        <TextBlock
                            Margin="0,16,0,0"
                            Foreground="#FF8FA7C4"
                            Text="截图时间" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding CaptureTime}" />
                        <TextBlock
                            Margin="0,16,0,0"
                            Foreground="#FF8FA7C4"
                            Text="分辨率" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding ImageSize}" />
                        <TextBlock
                            Margin="0,16,0,0"
                            Foreground="#FF8FA7C4"
                            Text="当前缩放" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding ZoomDisplayText}" />
                    </StackPanel>
                </Border>

                <Button
                    Height="44"
                    Margin="0,24,0,0"
                    Background="#1FFFFFFF"
                    BorderBrush="#33FFFFFF"
                    Command="{Binding TogglePreviewScaleCommand}"
                    Foreground="White">
                    <TextBlock Text="{Binding PreviewScaleModeText}" />
                </Button>

                <Button
                    Height="44"
                    Margin="0,12,0,0"
                    Background="#FF2563EB"
                    BorderThickness="0"
                    Command="{Binding SaveToFileCommand}"
                    Foreground="White">
                    <TextBlock Text="保存到文件" />
                </Button>

                <Button
                    Height="44"
                    Margin="0,12,0,0"
                    Background="#FF0F766E"
                    BorderThickness="0"
                    Command="{Binding CopyToClipboardCommand}"
                    Foreground="White">
                    <TextBlock Text="复制到剪贴板" />
                </Button>

                <Button
                    Height="44"
                    Margin="0,12,0,0"
                    Background="#1FFFFFFF"
                    BorderBrush="#33FFFFFF"
                    Command="{Binding RecaptureCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Foreground="White">
                    <TextBlock Text="重新截图" />
                </Button>

                <Button
                    Height="44"
                    Margin="0,12,0,0"
                    Background="#00FFFFFF"
                    BorderBrush="#33FFFFFF"
                    Command="{Binding CloseCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Foreground="#FFD7E4F5">
                    <TextBlock Text="关闭" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>