<Window
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="截图预览"
    Width="1040"
    Height="760"
    MinWidth="720"
    MinHeight="520"
    PreviewKeyDown="Window_PreviewKeyDown"
    WindowStartupLocation="CenterOwner">
    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>

    <Window.Resources>
        <DrawingBrush
            x:Key="TransparencyCheckerBrush"
            Stretch="None"
            TileMode="Tile"
            Viewbox="0,0,16,16"
            ViewboxUnits="Absolute"
            Viewport="0,0,16,16"
            ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFE7EDF5">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFD8E1EC">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8" />
                                <RectangleGeometry Rect="8,8,8,8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <DockPanel Background="#FFF3F6FA" LastChildFill="True">
        <ToolBarTray Background="#FFF3F6FA" DockPanel.Dock="Top">
            <ToolBar>
                <Button Command="{Binding SaveToFileCommand}">保存</Button>
                <Button Command="{Binding CopyToClipboardCommand}">复制</Button>
                <Separator />
                <Button Command="{Binding TogglePreviewScaleCommand}">切换缩放</Button>
                <Separator />
                <Button Command="{Binding RecaptureCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">重新截图</Button>
                <Button Command="{Binding CloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">关闭</Button>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding CaptureMode, StringFormat=模式: {0}}" />
            <Separator />
            <StatusBarItem Content="{Binding CaptureTime, StringFormat=时间: {0}}" />
            <Separator />
            <StatusBarItem Content="{Binding ImageSize, StringFormat=分辨率: {0}}" />
            <Separator />
            <StatusBarItem Content="{Binding ZoomDisplayText}" />
        </StatusBar>

        <Grid>
            <Border
                Margin="20"
                Background="White"
                BorderBrush="#FFD9E2EC"
                BorderThickness="1"
                PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
                <Grid
                    x:Name="PreviewViewport"
                    Background="{StaticResource TransparencyCheckerBrush}"
                    SizeChanged="PreviewViewport_SizeChanged">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="ClipToBounds" Value="True" />
                        </Style>
                    </Grid.Style>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Image
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{Binding ScreenshotImage}"
                            Stretch="Uniform"
                            StretchDirection="DownOnly" />
                    </Grid>

                    <ScrollViewer
                        x:Name="ActualSizeScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        MouseLeave="ActualSizeScrollViewer_MouseLeave"
                        PreviewMouseLeftButtonDown="ActualSizeScrollViewer_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="ActualSizeScrollViewer_PreviewMouseLeftButtonUp"
                        PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                        VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <Image
                            x:Name="ActualSizeImage"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{Binding ScreenshotImage}"
                            Stretch="None">
                            <Image.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>