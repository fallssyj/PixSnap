                        <Button
                            Height="44"
                            Margin="0,24,0,0"
                            Background="{DynamicResource PreviewGhostButtonBackgroundBrush}"
                            BorderBrush="{DynamicResource PreviewGhostButtonBorderBrush}"
                            Command="{Binding TogglePreviewScaleCommand}"
                            Foreground="{DynamicResource PreviewGhostButtonForegroundBrush}">
                            <TextBlock Text="{Binding PreviewScaleModeText}" />
                        </Button>

                        <Button
                            Height="44"
                            Margin="0,12,0,0"
