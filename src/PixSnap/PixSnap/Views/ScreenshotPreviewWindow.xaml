                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Foreground="{DynamicResource PreviewGhostButtonForegroundBrush}">
                            <TextBlock Text="重新截图" />
                        </Button>

                        <Button
                            Height="44"
                            Margin="0,12,0,0"
                            Background="Transparent"
                            BorderBrush="{DynamicResource PreviewGhostButtonBorderBrush}"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Foreground="{DynamicResource PreviewCloseButtonForegroundBrush}">
                            <TextBlock Text="关闭" />
                        </Button>
                    </StackPanel>
                </Border>-->
            </Grid>
            <Border
                x:Name="OverlayBorder"
                Panel.ZIndex="999"
                BorderBrush="{StaticResource AppGradientEndBrush}"
                BorderThickness="0.5"
                CornerRadius="10"
                IsHitTestVisible="False" />
        </Grid>


    </Border>
</Window>