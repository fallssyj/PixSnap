<Window
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    Title="截图预览"
    Width="1040"
    Height="760"
    MinWidth="1000"
    MinHeight="520"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>


    <Border
        x:Name="RootBorder"
        Background="{DynamicResource AppBackgroundBrush}"
        CornerRadius="10"
        MouseLeftButtonDown="OnWindowDragMove"
        Style="{StaticResource RoundedWindowBorderStyle}">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  顶部控制  -->
                <Grid Grid.Row="0">
                    <StackPanel
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button
                            Width="70"
                            Height="35"
                            Margin="10,5,0,5"
                            Command="{Binding OpenFileCommand}">
                            <Button.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Direction="315"
                                    Opacity="0.3"
                                    ShadowDepth="5"
                                    Color="Black" />
                            </Button.Effect>
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="15"
                                    Height="15"
                                    Data="{StaticResource ImageOn}"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Text="打开" />
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="ButtonRoot"
                                                    Background="{DynamicResource ButtonPrimaryBackgroundBrush}"
                                                    CornerRadius="5"
                                                    SnapsToDevicePixels="True">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        RecognizesAccessKey="True" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.96" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.88" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Margin="20,0,2,0"
                            Command="{Binding SaveToFileCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="保存">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource FloppyDisk}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding UndoCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="撤销">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource Undo}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding RedoCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="重做">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource Redo}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding RotateImageCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="旋转">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource Rotate}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding CopyToClipboardCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="复制到剪切板">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource RegularCopy}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding ToggleCropCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="裁剪">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource Crop}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>

                        <Button
                            Margin="2,0"
                            Command="{Binding ToggleRoundCornerCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="圆角">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource RoundedSquare}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Button
                            Margin="2,0"
                            Command="{Binding ToggleEraserCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="AI擦除">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource Eraser}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>

                        <Button
                            Margin="2,0"
                            Command="{Binding RecaptureCommand}"
                            Style="{StaticResource PreviewZoomIconButtonStyle}"
                            ToolTip="重新截图">
                            <Path
                                Width="15"
                                Height="15"
                                Data="{StaticResource Recapture}"
                                Fill="{DynamicResource TextPrimaryBrush}"
                                Stretch="Uniform" />
                        </Button>
                        <Border
                            Margin="30,0"
                            Padding="10,5"
                            Background="{DynamicResource AppBackgroundBrush}"
                            BorderBrush="{DynamicResource AppGradientEndBrush}"
                            BorderThickness="0.8"
                            CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Direction="315"
                                    Opacity="0.3"
                                    ShadowDepth="5"
                                    Color="Black" />
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    MaxWidth="420"
                                    Margin="5,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Text="{Binding CaptureTitleDisplay}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,0,0"
                            Command="{Binding OpenSettingsCommand}"
                            Content="{StaticResource Settings}"
                            Style="{StaticResource IconButton}"
                            ToolTip="设置" />
                        <Button
                            Margin="0,0,0,0"
                            Command="{Binding MinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{StaticResource minimize}"
                            Style="{StaticResource IconButton}"
                            ToolTip="最小化" />
                        <Button Command="{Binding MaximizeCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource IconButton}" TargetType="Button">
                                    <Setter Property="Content" Value="{StaticResource maximize}" />
                                    <Setter Property="ToolTip" Value="最大化" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                                            <Setter Property="Content" Value="{StaticResource restore}" />
                                            <Setter Property="ToolTip" Value="还原" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{StaticResource close}"
                            Style="{StaticResource CloseIconButton}"
                            ToolTip="关闭" />
                    </StackPanel>
                </Grid>

                <!--  预览区域  -->
                <Grid
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="{StaticResource TransparencyCheckerBrush}">
                    <Border PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
                        <Grid
                            x:Name="PreviewViewport"
                            ClipToBounds="True"
                            MouseRightButtonUp="PreviewViewport_MouseRightButtonUp"
                            SizeChanged="PreviewViewport_SizeChanged">
                            <Grid x:Name="FitPreviewHost">

                                <Image
                                    x:Name="FitPreviewImage"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="LowQuality"
                                    Source="{Binding ScreenshotImage}"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly" />
                            </Grid>

                            <ScrollViewer
                                x:Name="ActualSizeScrollViewer"
                                HorizontalScrollBarVisibility="Hidden"
                                MouseLeave="ActualSizeScrollViewer_MouseLeave"
                                PreviewMouseLeftButtonDown="ActualSizeScrollViewer_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ActualSizeScrollViewer_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                                VerticalScrollBarVisibility="Hidden"
                                Visibility="Collapsed">
                                <!--  Padding 在图片四周创建可滑动的空白区，实现拖动到边缘后还能继续拖动  -->
                                <Border Padding="200">
                                    <Image
                                        x:Name="ActualSizeImage"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="LowQuality"
                                        Source="{Binding ScreenshotImage}"
                                        Stretch="None">
                                        <Image.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </Border>
                            </ScrollViewer>

                            <!--  裁剪框覆盖层：只在裁剪模式下显示  -->
                            <controls:CropOverlayControl
                                x:Name="CropOverlay"
                                Visibility="Collapsed" />

                            <!--  AI 擦除涂抹覆盖层：Cursor=None 配合代码后置圆形光标指示器  -->
                            <Canvas
                                x:Name="EraserCanvas"
                                Background="Transparent"
                                Cursor="None"
                                IsHitTestVisible="False"
                                MouseEnter="EraserCanvas_MouseEnter"
                                MouseLeave="EraserCanvas_MouseLeave"
                                MouseLeftButtonDown="EraserCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="EraserCanvas_MouseLeftButtonUp"
                                MouseMove="EraserCanvas_MouseMove">
                                <!--  跟随鼠标的画刷轮廓（由代码后置动态定位和缩放）  -->
                                <Ellipse
                                    x:Name="EraserCursorIndicator"
                                    Fill="#224cc2ff"
                                    IsHitTestVisible="False"
                                    Stroke="#4cc2ff"
                                    StrokeThickness="2"
                                    Visibility="Collapsed" />
                            </Canvas>
                        </Grid>
                    </Border>

                    <!--  裁剪信息拖动面板  -->
                    <Border
                        x:Name="CropPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CropPanelTranslate" />
                        </Border.RenderTransform>
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <StackPanel MinWidth="220">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="裁剪" />
                            <!--  比例预设  -->
                            <WrapPanel Margin="0,0,0,8">
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="0:0:自由"
                                    Content="自由"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="自由裁剪" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="1:1:1:1"
                                    Content="1:1"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="正方形" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="16:9:16:9"
                                    Content="16:9"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="宽屏" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="4:3:4:3"
                                    Content="4:3"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="标准" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="3:2:3:2"
                                    Content="3:2"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="相机" />
                            </WrapPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding CropPanel.AspectRatioText, StringFormat='当前比例: {0}'}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!--  X  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪起始 X">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="X轴" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  Y  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪起始 Y">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Y轴" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  W  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪宽度">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="宽度" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  H  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪高度">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="高度" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding CropPanel.CancelCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消裁剪" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding CropPanel.ApplyCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="应用裁剪" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  圆角信息拖动面板  -->
                    <Border
                        x:Name="RoundCornerPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="RoundCornerPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="200">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="圆角" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="圆角半径(像素)" />
                                <TextBox
                                    Margin="5,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding RoundCornerPanel.CornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding RoundCornerPanel.CancelCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消圆角" />
                                <Button
                                    Command="{Binding RoundCornerPanel.ApplyCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="应用圆角" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  AI 擦除画刷大小浮动面板  -->
                    <Border
                        x:Name="EraserFloatingPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EraserFloatingPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="200">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="AI 擦除" />
                            <!--  画刷大小输入  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="画刷大小" />
                                <TextBox
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding EraserPanel.BrushSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="px" />
                            </StackPanel>
                            <Slider
                                Margin="0,8,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="200"
                                Minimum="5"
                                SmallChange="1"
                                TickFrequency="5"
                                Value="{Binding EraserPanel.BrushSize, Mode=TwoWay}" />

                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="边缘羽化" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="{Binding EraserPanel.EdgeFeatherStrengthText}" />
                            </StackPanel>
                            <Slider
                                Margin="0,6,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                TickFrequency="5"
                                Value="{Binding EraserPanel.EdgeFeatherStrength, Mode=TwoWay}" />

                            <!--  操作按钮  -->
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding EraserPanel.ClearStrokesCommand}"
                                    Content="清除"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="清除当前涂抹" />
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding ExitEraserModeCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消 AI 处理并退出擦除模式" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding ApplyEraserCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="执行 AI 修复" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Popup
                        x:Name="AiModulePopup"
                        AllowsTransparency="True"
                        IsOpen="{Binding IsAiPopupOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=AiModuleButton}"
                        PopupAnimation="Fade"
                        StaysOpen="False"
                        VerticalOffset="6">
                        <Border
                            MinWidth="180"
                            Padding="8"
                            Background="#E61A1A1A"
                            BorderBrush="#333"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel>
                                <Button
                                    Margin="0,0,0,6"
                                    Command="{Binding RemoveBackgroundCommand}"
                                    Content="去除背景"
                                    Style="{StaticResource PanelCancelButtonStyle}" />
                                <Button
                                    Command="{Binding SuperResolutionCommand}"
                                    Content="超分四倍"
                                    Style="{StaticResource PanelCancelButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </Popup>

                </Grid>
                <!--  控制区域  -->
                <Border
                    Grid.Row="2"
                    Padding="10"
                    Background="{DynamicResource AppGradientStartBrush}">
                    <!--  CornerRadius="0,0,10,10">  -->
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path
                                Width="15"
                                Height="15"
                                Margin="10,0"
                                Data="{StaticResource Maximize2}"
                                Fill="{DynamicResource TextMutedBrush}"
                                Stretch="Uniform" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding ImageSize}" />
                            <Path
                                Width="15"
                                Height="15"
                                Margin="10,0"
                                Data="{StaticResource BoxList}"
                                Fill="{DynamicResource TextMutedBrush}"
                                Stretch="Uniform" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding FileSize}" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Margin="2,0"
                                Command="{Binding TogglePreviewScaleCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="{Binding PreviewScaleModeText}">
                                <Path
                                    Width="15"
                                    Height="15"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource FitWindow}" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                                    <Setter Property="Data" Value="{StaticResource OriginalSize}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                            <ComboBox
                                Margin="2,0"
                                SelectedValue="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Tag"
                                Text="{Binding ZoomCompactText, Mode=OneWay}">
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="200%" Tag="200" />
                                <ComboBoxItem Content="300%" Tag="300" />
                                <ComboBoxItem Content="400%" Tag="400" />
                                <ComboBoxItem Content="500%" Tag="500" />
                                <ComboBoxItem Content="600%" Tag="600" />
                                <ComboBoxItem Content="700%" Tag="700" />
                                <ComboBoxItem Content="800%" Tag="800" />
                            </ComboBox>

                            <Button
                                Margin="2,0"
                                Command="{Binding ZoomOutCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="缩小">
                                <Path
                                    Width="15"
                                    Height="15"
                                    Data="{StaticResource ZoomOut}"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform" />
                            </Button>

                            <Slider
                                Margin="2,0"
                                IsSnapToTickEnabled="False"
                                LargeChange="25"
                                Maximum="800"
                                Minimum="10"
                                SmallChange="5"
                                TickFrequency="25"
                                Value="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button
                                Margin="2,0"
                                Command="{Binding ZoomInCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="放大">
                                <Path
                                    Width="15"
                                    Height="15"
                                    Data="{StaticResource ZoomIn}"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform" />
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>

            <!--  全窗口处理遮罩：处理期间阻断所有操作，完成或异常后自动隐藏  -->
            <Grid Panel.ZIndex="998">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnyAiProcessing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border Background="#80101010" />

                <Border
                    Margin="0,0,0,100"
                    Padding="16,12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Background="#CC1A1A1A"
                    CornerRadius="12">
                    <StackPanel MinWidth="280" Orientation="Vertical">
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Text="{Binding ActiveAiProgressText}" />
                        <ProgressBar
                            Height="6"
                            IsIndeterminate="{Binding IsAnyIndeterminateProcessing, Mode=OneWay}"
                            Maximum="1"
                            Minimum="0"
                            Value="{Binding ActiveAiProgress, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                x:Name="OverlayBorder"
                Panel.ZIndex="999"
                BorderBrush="{StaticResource AppGradientEndBrush}"
                BorderThickness="0.5"
                CornerRadius="10"
                IsHitTestVisible="False" />
        </Grid>


    </Border>
</Window>