<mica:MicaWindow
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:mica="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
    Title="截图预览"
    Width="1040"
    Height="760"
    MinWidth="1000"
    MinHeight="520"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="-1"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <mica:MicaWindow.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="V"
            Command="{Binding PasteFromClipboardCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="Z"
            Command="{Binding UndoCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="Y"
            Command="{Binding RedoCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="C"
            Command="{Binding CopyToClipboardCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="O"
            Command="{Binding OpenFileCommand}"
            Modifiers="Ctrl" />
    </mica:MicaWindow.InputBindings>


    <Border Background="{DynamicResource AppBackgroundBrush}" MouseLeftButtonDown="OnWindowDragMove">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  顶部控制  -->
                <Grid Grid.Row="0">
                    <StackPanel
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button
                            Width="80"
                            Height="35"
                            Margin="10,5,0,5"
                            Command="{Binding OpenFileCommand}"
                            Style="{StaticResource OpenFileButtonStyle}"
                            ToolTip="打开文件">
                            <Button.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Direction="315"
                                    Opacity="0.3"
                                    ShadowDepth="5"
                                    Color="Black" />
                            </Button.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="{StaticResource SegoeFluent}"
                                    FontSize="14"
                                    Text="{StaticResource Glyph_OpenImage}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Text="打开" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="20,0,2,0"
                            Command="{Binding SaveToFileCommand}"
                            Content="{StaticResource Glyph_Save}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="保存" />
                        <Button
                            Command="{Binding UndoCommand}"
                            Content="{StaticResource Glyph_Undo}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="撤销" />
                        <Button
                            Command="{Binding RedoCommand}"
                            Content="{StaticResource Glyph_Redo}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="重做" />
                        <Border Style="{StaticResource ToolbarSeparatorStyle}" />
                        <Button
                            Command="{Binding RotateImageCommand}"
                            Content="{StaticResource Glyph_Rotate}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="旋转" />
                        <Button
                            Command="{Binding CopyToClipboardCommand}"
                            Content="{StaticResource Glyph_Copy}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="复制到剪切板" />
                        <Border Style="{StaticResource ToolbarSeparatorStyle}" />
                        <Button
                            Command="{Binding ToggleCropCommand}"
                            Content="{StaticResource Glyph_Crop}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="裁剪" />
                        <Button
                            Command="{Binding ToggleRoundCornerCommand}"
                            Content="{StaticResource Glyph_RoundCorner}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="圆角" />
                        <Button
                            Command="{Binding ToggleEraserCommand}"
                            Content="{StaticResource Glyph_Eraser}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="AI擦除" />
                        <Button
                            Command="{Binding ToggleAnnotationCommand}"
                            Content="{StaticResource Glyph_Annotate}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="标注" />
                        <Border Style="{StaticResource ToolbarSeparatorStyle}" />
                        <Button
                            Command="{Binding RecaptureCommand}"
                            Content="{StaticResource Glyph_Recapture}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="重新截图" />
                        <Border
                            Height="30"
                            Margin="30,0"
                            Padding="10,5"
                            Background="{DynamicResource AppBackgroundBrush}"
                            BorderBrush="{DynamicResource AppGradientEndBrush}"
                            BorderThickness="0.8"
                            CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Direction="315"
                                    Opacity="0.3"
                                    ShadowDepth="5"
                                    Color="Black" />
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    MaxWidth="420"
                                    Margin="5,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="{Binding CaptureTitleDisplay}"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Button
                            Command="{Binding OpenLogFolderCommand}"
                            Content="{StaticResource Glyph_Diagnostic}"
                            Style="{StaticResource WindowIconButtonStyle}"
                            ToolTip="打开LOG" />
                        <Button
                            Command="{Binding OpenSettingsCommand}"
                            Content="{StaticResource Glyph_Settings}"
                            Style="{StaticResource WindowIconButtonStyle}"
                            ToolTip="设置" />
                        <Button
                            Command="{Binding MinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{StaticResource Glyph_Minimize}"
                            Style="{StaticResource WindowIconButtonStyle}"
                            ToolTip="最小化" />
                        <Button
                            Command="{Binding MaximizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            FontFamily="{StaticResource SegoeFluent}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource IconButton}" TargetType="Button">
                                    <Setter Property="ToolTip" Value="最大化" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                                            <Setter Property="ToolTip" Value="还原" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock FontFamily="{StaticResource SegoeFluent}" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{StaticResource Glyph_Maximize}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                                                <Setter Property="Text" Value="{StaticResource Glyph_Restore}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{StaticResource Glyph_Close}"
                            Style="{StaticResource CloseWindowIconButtonStyle}"
                            ToolTip="关闭" />
                    </StackPanel>
                </Grid>

                <!--  预览区域  -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <!--  Background="{StaticResource TransparencyCheckerBrush}">  -->
                    <Border PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
                        <Grid
                            x:Name="PreviewViewport"
                            ClipToBounds="True"
                            MouseRightButtonUp="PreviewViewport_MouseRightButtonUp"
                            SizeChanged="PreviewViewport_SizeChanged">
                            <Grid x:Name="FitPreviewHost">
                                <Image
                                    x:Name="FitPreviewImage"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderOptions.BitmapScalingMode="LowQuality"
                                    Source="{Binding ScreenshotImage}"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly" />
                            </Grid>

                            <ScrollViewer
                                x:Name="ActualSizeScrollViewer"
                                HorizontalScrollBarVisibility="Hidden"
                                MouseLeave="ActualSizeScrollViewer_MouseLeave"
                                PreviewMouseLeftButtonDown="ActualSizeScrollViewer_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ActualSizeScrollViewer_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                                VerticalScrollBarVisibility="Hidden"
                                Visibility="Collapsed">
                                <!--  Padding 在图片四周创建可滑动的空白区，实现拖动到边缘后还能继续拖动  -->
                                <Border Padding="200">
                                    <Image
                                        x:Name="ActualSizeImage"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="LowQuality"
                                        Source="{Binding ScreenshotImage}"
                                        Stretch="None">
                                        <Image.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </Border>
                            </ScrollViewer>

                            <!--  裁剪框覆盖层：只在裁剪模式下显示  -->
                            <controls:CropOverlayControl x:Name="CropOverlay" Visibility="Collapsed" />

                            <!--  AI 擦除涂抹覆盖层：Cursor=None 配合代码后置圆形光标指示器  -->
                            <Canvas
                                x:Name="EraserCanvas"
                                Background="Transparent"
                                Cursor="None"
                                IsHitTestVisible="False"
                                MouseEnter="EraserCanvas_MouseEnter"
                                MouseLeave="EraserCanvas_MouseLeave"
                                MouseLeftButtonDown="EraserCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="EraserCanvas_MouseLeftButtonUp"
                                MouseMove="EraserCanvas_MouseMove">
                                <!--  跟随鼠标的画刷轮廓（由代码后置动态定位和缩放）  -->
                                <Ellipse
                                    x:Name="EraserCursorIndicator"
                                    Fill="{DynamicResource AccentBrush}"
                                    IsHitTestVisible="False"
                                    Opacity="0.13"
                                    Stroke="{DynamicResource AccentBrush}"
                                    StrokeThickness="2"
                                    Visibility="Collapsed" />
                            </Canvas>

                            <!--  标注绘制覆盖层  -->
                            <Canvas
                                x:Name="AnnotationCanvas"
                                Background="Transparent"
                                IsHitTestVisible="False"
                                MouseLeftButtonDown="AnnotationCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="AnnotationCanvas_MouseLeftButtonUp"
                                MouseMove="AnnotationCanvas_MouseMove" />
                        </Grid>
                    </Border>

                    <!--  裁剪信息拖动面板  -->
                    <Border
                        x:Name="CropPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CropPanelTranslate" />
                        </Border.RenderTransform>
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <StackPanel MinWidth="220">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="裁剪" />
                            <!--  比例预设  -->
                            <WrapPanel Margin="0,0,0,8">
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="0:0"
                                    Content="自由"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="自由裁剪" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="1:1:1:1"
                                    Content="1:1"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="正方形" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="16:9:16:9"
                                    Content="16:9"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="宽屏" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="4:3:4:3"
                                    Content="4:3"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="标准" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding CropPanel.SetAspectRatioFromParamCommand}"
                                    CommandParameter="3:2:3:2"
                                    Content="3:2"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="相机" />
                            </WrapPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontSize="11"
                                Text="{Binding CropPanel.AspectRatioDisplayText}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!--  X  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪起始 X">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="X轴" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  Y  -->
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪起始 Y">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Y轴" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  W  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪宽度">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="宽度" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <!--  H  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    ToolTip="裁剪高度">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="高度" />
                                    <TextBox
                                        Margin="5,0,0,0"
                                        Style="{StaticResource FieldInputStyle}"
                                        Text="{Binding CropPanel.CropHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding CropPanel.CancelCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消裁剪" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding CropPanel.ApplyCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="应用裁剪" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  圆角信息拖动面板  -->
                    <Border
                        x:Name="RoundCornerPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="RoundCornerPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="200">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="圆角" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="圆角半径(像素)" />
                                <TextBox
                                    Margin="5,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding RoundCornerPanel.CornerRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding RoundCornerPanel.CancelCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消圆角" />
                                <Button
                                    Command="{Binding RoundCornerPanel.ApplyCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="应用圆角" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  AI 擦除画刷大小浮动面板  -->
                    <Border
                        x:Name="EraserFloatingPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EraserFloatingPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="200">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="AI 擦除" />
                            <!--  画刷大小输入  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="画刷大小" />
                                <TextBox
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding EraserPanel.BrushSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="px" />
                            </StackPanel>
                            <Slider
                                Margin="0,8,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="200"
                                Minimum="5"
                                SmallChange="1"
                                TickFrequency="5"
                                Value="{Binding EraserPanel.BrushSize, Mode=TwoWay}" />

                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="边缘羽化" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="{Binding EraserPanel.EdgeFeatherStrengthText}" />
                            </StackPanel>
                            <Slider
                                Margin="0,6,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="1"
                                TickFrequency="5"
                                Value="{Binding EraserPanel.EdgeFeatherStrength, Mode=TwoWay}" />

                            <!--  操作按钮  -->
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding EraserPanel.ClearStrokesCommand}"
                                    Content="清除"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="清除当前涂抹" />
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding ExitEraserModeCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消 AI 处理并退出擦除模式" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding ApplyEraserCommand}"
                                    CommandParameter="{Binding ScreenshotImage}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="执行 AI 修复" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  标注工具浮动面板  -->
                    <Border
                        x:Name="AnnotationFloatingPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MouseLeftButtonDown="EditPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="EditPanel_MouseLeftButtonUp"
                        MouseMove="EditPanel_MouseMove"
                        Style="{StaticResource FloatingPanelStyle}"
                        Visibility="Collapsed">
                        <Border.Margin>
                            <Thickness Right="20" Top="20" />
                        </Border.Margin>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="AnnotationFloatingPanelTranslate" />
                        </Border.RenderTransform>
                        <StackPanel MinWidth="220">
                            <TextBlock Style="{StaticResource PanelTitleStyle}" Text="标注" />
                            <!--  工具选择  -->
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Opacity="0.6"
                                Text="工具" />
                            <WrapPanel Margin="0,0,0,8">
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding AnnotationPanel.SelectArrowCommand}"
                                    Content="箭头"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="箭头" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding AnnotationPanel.SelectRectangleCommand}"
                                    Content="矩形"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="矩形" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding AnnotationPanel.SelectEllipseCommand}"
                                    Content="椭圆"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="椭圆" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding AnnotationPanel.SelectTextCommand}"
                                    Content="文本"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="文本标注" />
                                <Button
                                    Margin="0,0,4,4"
                                    Command="{Binding AnnotationPanel.SelectPenCommand}"
                                    Content="画笔"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="自由画笔" />
                            </WrapPanel>
                            <!--  颜色选择  -->
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="11"
                                Opacity="0.6"
                                Text="颜色" />
                            <WrapPanel Margin="0,0,0,8">
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,4,4"
                                    Background="#FFFF0000"
                                    Command="{Binding AnnotationPanel.SetColorRedCommand}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="红色" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,4,4"
                                    Background="#FF3399FF"
                                    Command="{Binding AnnotationPanel.SetColorBlueCommand}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="蓝色" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,4,4"
                                    Background="#FF22CC55"
                                    Command="{Binding AnnotationPanel.SetColorGreenCommand}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="绿色" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,4,4"
                                    Background="#FFFFCC00"
                                    Command="{Binding AnnotationPanel.SetColorYellowCommand}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="黄色" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,4,4"
                                    Background="#FFFFFFFF"
                                    Command="{Binding AnnotationPanel.SetColorWhiteCommand}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="白色" />
                                <Button
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,4,4"
                                    Background="#FF000000"
                                    Command="{Binding AnnotationPanel.SetColorBlackCommand}"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="黑色" />
                            </WrapPanel>
                            <!--  线宽  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="线宽" />
                                <TextBox
                                    Margin="6,0,0,0"
                                    Style="{StaticResource FieldInputStyle}"
                                    Text="{Binding AnnotationPanel.StrokeWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    Style="{StaticResource FieldLabelStyle}"
                                    Text="px" />
                            </StackPanel>
                            <Slider
                                Margin="0,6,0,0"
                                IsSnapToTickEnabled="True"
                                LargeChange="2"
                                Maximum="20"
                                Minimum="1"
                                SmallChange="1"
                                TickFrequency="1"
                                Value="{Binding AnnotationPanel.StrokeWidth, Mode=TwoWay}" />
                            <!--  操作按钮  -->
                            <StackPanel
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding AnnotationPanel.UndoAnnotationCommand}"
                                    Content="撤销"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="撤销上一条标注" />
                                <Button
                                    Margin="0,0,6,0"
                                    Command="{Binding ExitAnnotationModeCommand}"
                                    Content="取消"
                                    Style="{StaticResource PanelCancelButtonStyle}"
                                    ToolTip="取消标注" />
                                <Button
                                    Padding="10,2"
                                    Command="{Binding ApplyAnnotationCommand}"
                                    Content="应用"
                                    Style="{StaticResource PanelApplyButtonStyle}"
                                    ToolTip="将标注合并到图像" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Popup
                        x:Name="AiModulePopup"
                        AllowsTransparency="True"
                        IsOpen="{Binding IsAiPopupOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=AiModuleButton}"
                        PopupAnimation="Fade"
                        StaysOpen="False"
                        VerticalOffset="6">
                        <Border
                            MinWidth="180"
                            Padding="8"
                            Background="#E61A1A1A"
                            BorderBrush="#333"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel>
                                <Button
                                    Margin="0,0,0,6"
                                    Command="{Binding RemoveBackgroundCommand}"
                                    Content="去除背景"
                                    Style="{StaticResource PanelCancelButtonStyle}" />
                                <Button
                                    Command="{Binding SuperResolutionCommand}"
                                    Content="超分四倍"
                                    Style="{StaticResource PanelCancelButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </Popup>

                </Grid>
                <!--  控制区域  -->
                <Border Grid.Row="2" Padding="10">
                    <!--  CornerRadius="0,0,10,10">  -->
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock
                                Margin="10,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource SegoeFluent}"
                                FontSize="14"
                                Opacity="0.6"
                                Text="{StaticResource Glyph_Resolution}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Opacity="0.6"
                                Text="{Binding ImageSize}" />
                            <TextBlock
                                Margin="10,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource SegoeFluent}"
                                FontSize="14"
                                Opacity="0.6"
                                Text="{StaticResource Glyph_List}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Opacity="0.6"
                                Text="{Binding FileSize}" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Margin="2,0"
                                Command="{Binding TogglePreviewScaleCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="{Binding PreviewScaleModeText}">
                                <Grid>
                                    <TextBlock
                                        FontFamily="{StaticResource SegoeFluent}"
                                        FontSize="14"
                                        Text="{StaticResource Glyph_FitWindow}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource SegoeFluent}"
                                        FontSize="5"
                                        Text="{StaticResource Glyph_OriginalSize}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                            <ComboBox
                                Height="35"
                                Margin="2,0"
                                SelectedValue="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Tag"
                                Text="{Binding ZoomCompactText, Mode=OneWay}">
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="200%" Tag="200" />
                                <ComboBoxItem Content="300%" Tag="300" />
                                <ComboBoxItem Content="400%" Tag="400" />
                                <ComboBoxItem Content="500%" Tag="500" />
                                <ComboBoxItem Content="600%" Tag="600" />
                                <ComboBoxItem Content="700%" Tag="700" />
                                <ComboBoxItem Content="800%" Tag="800" />
                            </ComboBox>

                            <Button
                                Command="{Binding ZoomOutCommand}"
                                Content="{StaticResource Glyph_ZoomOut}"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                ToolTip="缩小" />

                            <Slider
                                Margin="2,0"
                                IsSnapToTickEnabled="False"
                                LargeChange="25"
                                Maximum="800"
                                Minimum="10"
                                SmallChange="5"
                                TickFrequency="25"
                                Value="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button
                                Command="{Binding ZoomInCommand}"
                                Content="{StaticResource Glyph_ZoomIn}"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                ToolTip="放大" />
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>

            <!--  全窗口处理遮罩：处理期间阻断所有操作，完成或异常后自动隐藏  -->
            <Grid Panel.ZIndex="998">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnyAiProcessing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border Background="#80101010" />

                <Border
                    Margin="0,0,0,100"
                    Padding="16,12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    CornerRadius="12">
                    <StackPanel MinWidth="280" Orientation="Vertical">
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Text="{Binding ActiveAiProgressText}" />
                        <ProgressBar
                            Height="6"
                            IsIndeterminate="{Binding IsAnyIndeterminateProcessing, Mode=OneWay}"
                            Maximum="1"
                            Minimum="0"
                            Value="{Binding ActiveAiProgress, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>


    </Border>
</mica:MicaWindow>