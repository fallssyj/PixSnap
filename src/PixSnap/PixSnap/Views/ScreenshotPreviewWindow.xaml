<Window
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="截图预览"
    Width="1040"
    Height="760"
    MinWidth="1000"
    MinHeight="520"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>


    <Border
        x:Name="RootBorder"
        Background="{DynamicResource AppBackgroundBrush}"
        CornerRadius="10"
        MouseLeftButtonDown="OnWindowDragMove"
        Style="{StaticResource RoundedWindowBorderStyle}">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  顶部控制  -->
                <Grid Grid.Row="0">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,0,0"
                            Command="{Binding MinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{StaticResource minimize}"
                            Style="{StaticResource IconButton}"
                            ToolTip="最小化" />
                        <Button Command="{Binding MaximizeCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource IconButton}" TargetType="Button">
                                    <Setter Property="Content" Value="{StaticResource maximize}" />
                                    <Setter Property="ToolTip" Value="最大化" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                                            <Setter Property="Content" Value="{StaticResource restore}" />
                                            <Setter Property="ToolTip" Value="还原" />

                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{StaticResource close}"
                            Style="{StaticResource CloseIconButton}"
                            ToolTip="关闭" />
                    </StackPanel>
                </Grid>
                <!--  预览区域  -->
                <Grid
                    Grid.Row="1"
                    Margin="20"
                    Background="{StaticResource TransparencyCheckerBrush}">
                    <Border PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
                        <Grid
                            x:Name="PreviewViewport"
                            ClipToBounds="True"
                            SizeChanged="PreviewViewport_SizeChanged">
                            <Grid x:Name="FitPreviewHost">

                                <Image
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{Binding ScreenshotImage}"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly" />
                            </Grid>

                            <ScrollViewer
                                x:Name="ActualSizeScrollViewer"
                                HorizontalScrollBarVisibility="Hidden"
                                MouseLeave="ActualSizeScrollViewer_MouseLeave"
                                PreviewMouseLeftButtonDown="ActualSizeScrollViewer_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ActualSizeScrollViewer_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                                VerticalScrollBarVisibility="Hidden"
                                Visibility="Collapsed">
                                <Image
                                    x:Name="ActualSizeImage"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="{Binding ScreenshotImage}"
                                    Stretch="None">
                                    <Image.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                                    </Image.LayoutTransform>
                                </Image>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                <!--  控制区域  -->
                <Border
                    Grid.Row="2"
                    Padding="10"
                    Background="{DynamicResource AppGradientStartBrush}">
                    <!--  CornerRadius="0,0,10,10">  -->
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Path
                                Width="15"
                                Height="15"
                                Margin="10,0"
                                Data="{StaticResource BoxList}"
                                Fill="{DynamicResource TextMutedBrush}"
                                Stretch="Uniform" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding CaptureMode}" />
                            <Path
                                Width="15"
                                Height="15"
                                Margin="10,0"
                                Data="{StaticResource Crop}"
                                Fill="{DynamicResource TextMutedBrush}"
                                Stretch="Uniform" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding ImageSize}" />
                            <Path
                                Width="15"
                                Height="15"
                                Margin="10,0"
                                Data="{StaticResource ImageOn}"
                                Fill="{DynamicResource TextMutedBrush}"
                                Stretch="Uniform" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="{Binding FileSize}" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Margin="2,0"
                                Command="{Binding TogglePreviewScaleCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="{Binding PreviewScaleModeText}">
                                <Path
                                    Width="18"
                                    Height="18"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource FitWindow}" />

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActualSize}" Value="True">
                                                    <Setter Property="Data" Value="{StaticResource OriginalSize}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                            <ComboBox
                                Margin="2,0"
                                SelectedValue="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Tag"
                                Text="{Binding ZoomCompactText, Mode=OneWay}">
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="200%" Tag="200" />
                                <ComboBoxItem Content="300%" Tag="300" />
                                <ComboBoxItem Content="400%" Tag="400" />
                                <ComboBoxItem Content="500%" Tag="500" />
                                <ComboBoxItem Content="600%" Tag="600" />
                                <ComboBoxItem Content="700%" Tag="700" />
                                <ComboBoxItem Content="800%" Tag="800" />
                            </ComboBox>

                            <Button
                                Margin="2,0"
                                Command="{Binding ZoomOutCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="缩小">
                                <Path
                                    Width="18"
                                    Height="18"
                                    Data="{StaticResource ZoomOut}"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform" />
                            </Button>

                            <Slider
                                Margin="2,0"
                                IsSnapToTickEnabled="False"
                                LargeChange="25"
                                Maximum="800"
                                Minimum="10"
                                SmallChange="5"
                                Style="{StaticResource PreviewZoomSliderStyle}"
                                TickFrequency="25"
                                Value="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Button
                                Margin="2,0"
                                Command="{Binding ZoomInCommand}"
                                Style="{StaticResource PreviewZoomIconButtonStyle}"
                                ToolTip="放大">
                                <Path
                                    Width="18"
                                    Height="18"
                                    Data="{StaticResource ZoomIn}"
                                    Fill="{DynamicResource TextPrimaryBrush}"
                                    Stretch="Uniform" />
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>



                <!--<Border
                    Margin="0,20,20,20"
                    Padding="22"
                    Background="{DynamicResource PreviewSidebarBackgroundBrush}"
                    CornerRadius="24"
                    Visibility="Hidden">
                    <StackPanel>
