<Window
    x:Class="PixSnap.Views.ScreenshotPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:converters="clr-namespace:PixSnap.Converters"
    xmlns:local="clr-namespace:PixSnap.Views"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:toolPanels="clr-namespace:PixSnap.Controls.ToolPanels"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="截图预览"
    Width="{x:Static local:ScreenshotPreviewWindow.DefaultWidth}"
    Height="{x:Static local:ScreenshotPreviewWindow.DefaultHeight}"
    MinWidth="{x:Static local:ScreenshotPreviewWindow.MinWindowWidth}"
    MinHeight="{x:Static local:ScreenshotPreviewWindow.MinWindowHeight}"
    ui:TitleBar.ExtendViewIntoTitleBar="True"
    ui:TitleBar.Height="36"
    ui:TitleBar.IsIconVisible="False"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True"
    Icon="/Assets/icons/picture.png"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveToFileCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="V"
            Command="{Binding PasteFromClipboardCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="Z"
            Command="{Binding UndoCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="Y"
            Command="{Binding RedoCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="C"
            Command="{Binding CopyToClipboardCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="C"
            Command="{Binding ApplyAnnotationAndCopyCommand}"
            Modifiers="Ctrl+Shift" />
        <KeyBinding
            Key="O"
            Command="{Binding OpenFileCommand}"
            Modifiers="Ctrl" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:TitleBarInsetMarginConverter x:Key="TitleBarInsetMarginConverter" />
    </Window.Resources>

    <Grid>
        <!--  标题栏工具栏（ExtendViewIntoTitleBar 区域）  -->
        <Grid
            Height="48"
            VerticalAlignment="Top"
            Panel.ZIndex="2">
            <Grid.Margin>
                <Binding
                    Converter="{StaticResource TitleBarInsetMarginConverter}"
                    Path="."
                    RelativeSource="{RelativeSource AncestorType=Window}" />
            </Grid.Margin>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <controls:PreviewTitleBarToolbar VerticalAlignment="Center" />
        </Grid>

        <Grid Margin="0,48,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  预览区域  -->
            <Grid Grid.Row="0">
                <!--  Background="{StaticResource TransparencyCheckerBrush}">  -->
                <Border PreviewMouseWheel="PreviewHost_PreviewMouseWheel">
                    <Grid
                        x:Name="PreviewViewport"
                        ClipToBounds="True"
                        Focusable="True"
                        MouseRightButtonUp="PreviewViewport_MouseRightButtonUp"
                        SizeChanged="PreviewViewport_SizeChanged">
                        <ScrollViewer
                            x:Name="ActualSizeScrollViewer"
                            HorizontalScrollBarVisibility="Hidden"
                            MouseLeave="ActualSizeScrollViewer_MouseLeave"
                            PreviewMouseDown="ActualSizeScrollViewer_PreviewMouseDown"
                            PreviewMouseMove="ActualSizeScrollViewer_PreviewMouseMove"
                            PreviewMouseUp="ActualSizeScrollViewer_PreviewMouseUp"
                            VerticalScrollBarVisibility="Hidden">
                            <!--  Padding 在图片四周创建可滑动的空白区，实现拖动到边缘后还能继续拖动  -->
                            <Border Padding="200">
                                <Grid>
                                    <Grid.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}" />
                                    </Grid.LayoutTransform>
                                    <Image
                                        x:Name="ActualSizeImage"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="LowQuality"
                                        Source="{Binding ScreenshotImage}"
                                        Stretch="None" />
                                    <!--  标注绘制覆盖层  -->
                                    <controls:AnnotationOverlayControl
                                        ImageSource="{Binding ScreenshotImage}"
                                        IsActive="{Binding IsAnnotateMode}"
                                        ViewModel="{Binding AnnotationPanel}" />

                                    <!--  OCR 文字原位覆盖层  -->
                                    <controls:OcrOverlayControl
                                        ImageSource="{Binding ScreenshotImage}"
                                        IsActive="{Binding IsOcrOverlayVisible}"
                                        Regions="{Binding OcrRegions}" />

                                    <!--  AI 擦除涂抹覆盖层：与图片同大同缩放，Cursor=None 配合代码后置圆形光标指示器  -->
                                    <Canvas
                                        x:Name="EraserCanvas"
                                        Background="Transparent"
                                        Cursor="None"
                                        IsHitTestVisible="False"
                                        MouseEnter="EraserCanvas_MouseEnter"
                                        MouseLeave="EraserCanvas_MouseLeave"
                                        MouseLeftButtonDown="EraserCanvas_MouseLeftButtonDown"
                                        MouseLeftButtonUp="EraserCanvas_MouseLeftButtonUp"
                                        MouseMove="EraserCanvas_MouseMove">
                                        <!--  跟随鼠标的画刷轮廓（由代码后置动态定位和缩放）  -->
                                        <Ellipse
                                            x:Name="EraserCursorIndicator"
                                            Fill="{DynamicResource SystemControlForegroundAccentBrush}"
                                            IsHitTestVisible="False"
                                            Opacity="0.13"
                                            Stroke="{DynamicResource SystemControlForegroundAccentBrush}"
                                            StrokeThickness="2"
                                            Visibility="Collapsed" />
                                    </Canvas>
                                </Grid>
                            </Border>
                        </ScrollViewer>

                        <!--  裁剪框覆盖层：只在裁剪模式下显示  -->
                        <controls:CropOverlayControl x:Name="CropOverlay" Visibility="{Binding IsCropMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!--  圆角预览蒙版：只在圆角模式下显示  -->
                        <controls:RoundCornerPreviewOverlay x:Name="RoundCornerOverlay" Visibility="{Binding IsRoundCornerMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!--  编辑工具条：画布底部居中  -->
                        <Grid
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="20">
                            <controls:AnnotationDockBar
                                DataContext="{Binding}"
                                Visibility="{Binding IsAnnotateMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <controls:OcrDockBar
                                DataContext="{Binding}"
                                Visibility="{Binding IsOcrOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <toolPanels:CropToolPanelView Visibility="{Binding IsCropMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <toolPanels:RoundCornerToolPanelView Visibility="{Binding IsRoundCornerMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <toolPanels:EraserToolPanelView Visibility="{Binding IsEraserMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                    </Grid>
                </Border>

                <Popup
                    x:Name="AiModulePopup"
                    AllowsTransparency="True"
                    IsOpen="{Binding IsAiPopupOpen, Mode=TwoWay}"
                    Placement="Relative"
                    PlacementTarget="{Binding ElementName=PreviewViewport}"
                    PopupAnimation="Fade"
                    StaysOpen="False">
                    <controls:AiContextMenuPopup DataContext="{Binding}" />
                </Popup>

            </Grid>
            <!--  控制区域  -->
            <Border Grid.Row="1" Padding="10">
                <!--  CornerRadius="0,0,10,10">  -->
                <Grid>
                    <StackPanel
                        Margin="4,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ImageSize.Length}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Border>
                            <Border.Style>
                                <Style BasedOn="{StaticResource PreviewMetaChipStyle}" TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Icon="{x:Static ui:SegoeFluentIcons.OpenFile}"
                                    Style="{StaticResource PreviewMetaChipIconStyle}" />
                                <TextBlock
                                    Style="{StaticResource PreviewMetaChipLabelStyle}"
                                    Text="文件" />
                                <TextBlock
                                    Style="{StaticResource PreviewMetaChipFilenameTextStyle}"
                                    Text="{Binding CaptureTitleDisplay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PreviewMetaChipStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Icon="{x:Static ui:SegoeFluentIcons.Picture}"
                                    Style="{StaticResource PreviewMetaChipIconStyle}" />
                                <TextBlock
                                    Style="{StaticResource PreviewMetaChipLabelStyle}"
                                    Text="尺寸" />
                                <TextBlock
                                    Style="{StaticResource PreviewMetaChipTextStyle}"
                                    Text="{Binding ImageSize}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PreviewMetaChipStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    Icon="{x:Static ui:SegoeFluentIcons.Document}"
                                    Style="{StaticResource PreviewMetaChipIconStyle}" />
                                <TextBlock
                                    Style="{StaticResource PreviewMetaChipLabelStyle}"
                                    Text="大小" />
                                <TextBlock
                                    Style="{StaticResource PreviewMetaChipTextStyle}"
                                    Text="{Binding FileSize}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            x:Name="ScanTextButton"
                            Margin="2,0,10,0"
                            Command="{Binding RecognizeTextCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="扫描文本（PaddleOCR 离线）">
                            <ui:FontIcon FontSize="14" Glyph="&#xE8A1;" />
                        </Button>
                        <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnnotateMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button
                            Margin="2,0"
                            Command="{Binding TogglePreviewScaleCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="{Binding PreviewScaleModeText}">
                            <Grid>
                                <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.FitPage}" />
                                <ui:FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="8"
                                    Glyph="&#xEA3B;"
                                    Visibility="{Binding IsActualSize, Converter={StaticResource InverseBoolToVisibility}}" />
                            </Grid>
                        </Button>
                        <TextBlock
                            Width="48"
                            Margin="2,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding ZoomCompactText}"
                            TextAlignment="Center" />

                        <Button
                            Command="{Binding ZoomOutCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="缩小">
                            <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.ZoomOut}" />
                        </Button>

                        <Slider
                            Width="150"
                            Margin="2,0"
                            VerticalAlignment="Center"
                            IsSnapToTickEnabled="False"
                            LargeChange="25"
                            Maximum="800"
                            Minimum="10"
                            SmallChange="5"
                            TickFrequency="25"
                            Value="{Binding ZoomSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button
                            Command="{Binding ZoomInCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="放大">
                            <ui:FontIcon FontSize="14" Icon="{x:Static ui:SegoeFluentIcons.ZoomIn}" />
                        </Button>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>

        <!--  全窗口处理遮罩：处理期间阻断所有操作，完成或异常后自动隐藏  -->
        <Grid Panel.ZIndex="998">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="IsHitTestVisible" Value="False" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyAiProcessing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                            <Setter Property="IsHitTestVisible" Value="True" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="{StaticResource OverlayMaskBrush}" />

            <Border
                Margin="0,0,0,100"
                Padding="16,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel MinWidth="280" Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{Binding ActiveAiProgressText}" />
                    <ProgressBar
                        Height="6"
                        IsIndeterminate="{Binding IsAnyIndeterminateProcessing, Mode=OneWay}"
                        Maximum="1"
                        Minimum="0"
                        Value="{Binding ActiveAiProgress, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
