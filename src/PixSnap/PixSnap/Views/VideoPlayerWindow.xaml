<Window
    x:Class="PixSnap.Views.VideoPlayerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:PixSnap.Behaviors"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="录屏预览 仅作预览 如需要裁剪 请使用其它工具"
    Width="800"
    Height="520"
    MinWidth="480"
    MinHeight="360"
    Icon="/Assets/icons/video.png"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True">

    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="Space" Command="{Binding PlayPauseCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  视频区域  -->
        <Border
            Grid.Row="0"
            Background="Black"
            ClipToBounds="True">
            <MediaElement
                x:Name="VideoPlayer"
                LoadedBehavior="Manual"
                Stretch="Uniform"
                UnloadedBehavior="Stop" />
        </Border>

        <!--  底部控制栏  -->
        <Border
            Grid.Row="1"
            Padding="16,10"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  进度条  -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding PositionText}" />
                    <Slider
                        Grid.Column="1"
                        Margin="10,0"
                        VerticalAlignment="Center"
                        behaviors:SliderDragBehavior.DragCompletedCommand="{Binding DragCompletedCommand}"
                        behaviors:SliderDragBehavior.DragStartedCommand="{Binding DragStartedCommand}"
                        IsMoveToPointEnabled="True"
                        Maximum="1"
                        Minimum="0"
                        Value="{Binding SliderValue, Mode=TwoWay}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <b:InvokeCommandAction Command="{Binding SliderClickCommand}" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </Slider>
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding DurationText}" />
                </Grid>

                <!--  按钮行  -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  左侧占位  -->

                    <!--  中间播放 + 保存  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,16,0"
                            Command="{Binding PlayPauseCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="播放 / 暂停 (Space)">
                            <ui:FontIcon FontSize="18">
                                <ui:FontIcon.Style>
                                    <Style TargetType="ui:FontIcon">
                                        <Setter Property="Icon" Value="{x:Static ui:SegoeFluentIcons.Play}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <Setter Property="Icon" Value="{x:Static ui:SegoeFluentIcons.Pause}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:FontIcon.Style>
                            </ui:FontIcon>
                        </Button>
                        <Button
                            Width="100"
                            Height="36"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PixSnapAccentButtonStyle}"
                            ToolTip="保存 (Ctrl+S)">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Icon="{x:Static ui:SegoeFluentIcons.Save}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="保存" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!--  右侧音量控制  -->
                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{Binding ToggleMuteCommand}"
                            Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="静音">
                            <ui:FontIcon FontSize="14">
                                <ui:FontIcon.Style>
                                    <Style TargetType="ui:FontIcon">
                                        <Setter Property="Icon" Value="{x:Static ui:SegoeFluentIcons.Volume}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                                <Setter Property="Icon" Value="{x:Static ui:SegoeFluentIcons.Mute}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:FontIcon.Style>
                            </ui:FontIcon>
                        </Button>
                        <Slider
                            MinWidth="100"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            IsMoveToPointEnabled="True"
                            Maximum="1"
                            Minimum="0"
                            Value="{Binding Volume, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
