<Window
    x:Class="PixSnap.Views.DisclaimerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="免责声明"
    Width="560"
    Height="640"
    MinWidth="480"
    MinHeight="480"
    ResizeMode="CanResize"
    TextOptions.TextFormattingMode="Display"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    ui:TitleBar.Height="36"
    ui:TitleBar.MaximizeButtonAvailability="Collapsed"
    ui:TitleBar.MinimizeButtonAvailability="Collapsed"
    ui:WindowHelper.FixMaximizedWindow="True"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,22,28,10">
            <controls:PageHeader Subtitle="{Binding Subtitle}" Title="{Binding Title}">
                <controls:PageHeader.IconContent>
                    <ui:FontIcon
                        FontSize="18"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        Icon="{x:Static ui:SegoeFluentIcons.Document}" />
                </controls:PageHeader.IconContent>
            </controls:PageHeader>
        </Border>

        <Border
            Grid.Row="1"
            Height="1"
            Margin="28,0"
            Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer
            Grid.Row="2"
            Padding="28,14,28,8"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ikw:SimpleStackPanel MaxWidth="520" Spacing="18">
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Text="{Binding Title}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    LineHeight="20"
                                    Text="{Binding Body}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ikw:SimpleStackPanel>
        </ScrollViewer>

        <Border
            x:Name="ViewFooter"
            Grid.Row="3"
            Padding="28,12,28,18"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <ui:HyperlinkButton
                    VerticalAlignment="Center"
                    Content="第三方许可摘要 (THIRD_PARTY_NOTICES)"
                    NavigateUri="{Binding ThirdPartyNoticesUrl}"
                    Style="{StaticResource AboutLinkButtonStyle}" />
                <Button
                    MinWidth="96"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"
                    Content="关闭"
                    IsDefault="True"
                    Style="{StaticResource PixSnapAccentButtonStyle}" />
            </Grid>
        </Border>

        <Border
            x:Name="AcceptanceFooter"
            Grid.Row="3"
            Padding="28,12,28,18"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="Collapsed">
            <Grid>
                <ui:HyperlinkButton
                    VerticalAlignment="Center"
                    Content="第三方许可摘要 (THIRD_PARTY_NOTICES)"
                    NavigateUri="{Binding ThirdPartyNoticesUrl}"
                    Style="{StaticResource AboutLinkButtonStyle}" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        MinWidth="96"
                        Margin="0,0,8,0"
                        Click="RejectButton_Click"
                        Content="拒绝"
                        Style="{StaticResource SettingsActionButtonStyle}" />
                    <Button
                        MinWidth="96"
                        Click="AcceptButton_Click"
                        Content="我同意"
                        IsDefault="True"
                        Style="{StaticResource PixSnapAccentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
