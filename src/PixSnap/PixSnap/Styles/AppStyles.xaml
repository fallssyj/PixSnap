<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:PixSnap.Converters"
    xmlns:s="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:PixSnap.ViewModels">

    <Thickness x:Key="DialogContentPadding">22,18,22,22</Thickness>
    <s:Double x:Key="SpacingSmall">8</s:Double>
    <s:Double x:Key="SpacingMedium">16</s:Double>
    <s:Double x:Key="SpacingLarge">24</s:Double>

    <Style x:Key="RoundedWindowBorderStyle" TargetType="Border">
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Clip">
            <Setter.Value>
                <MultiBinding Converter="{x:Static converters:RoundedClipConverter.Instance}">
                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}" />
                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}" />
                    <Binding Path="CornerRadius" RelativeSource="{RelativeSource Self}" />
                    <Binding Path="BorderThickness" RelativeSource="{RelativeSource Self}" />
                </MultiBinding>
            </Setter.Value>
        </Setter>
    </Style>

    <DrawingBrush
        x:Key="TransparencyCheckerBrush"
        Stretch="None"
        TileMode="Tile"
        Viewbox="0,0,16,16"
        ViewboxUnits="Absolute"
        Viewport="0,0,16,16"
        ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource PreviewCheckerLightBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,16,16" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource PreviewCheckerDarkBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,8,8" />
                            <RectangleGeometry Rect="8,8,8,8" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style
        x:Key="ToolbarIconButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style x:Key="PreviewToolbarSeparatorStyle" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
    </Style>

    <Style
        x:Key="PreviewPrimaryActionButtonStyle"
        BasedOn="{StaticResource PixSnapAccentButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="80" />
        <Setter Property="Height" Value="35" />
        <Setter Property="Margin" Value="10,5,0,5" />
    </Style>

    <Style x:Key="PreviewTitleChipStyle" TargetType="Border">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="30,0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
        <Setter Property="BorderThickness" Value="0.8" />
        <Setter Property="CornerRadius" Value="5" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PreviewTitleTextStyle" TargetType="TextBlock">
        <Setter Property="MaxWidth" Value="420" />
        <Setter Property="Margin" Value="5,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="FloatingPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style
        x:Key="RightTopFloatingPanelStyle"
        BasedOn="{StaticResource FloatingPanelStyle}"
        TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,20,20,0" />
    </Style>

    <Style x:Key="PanelInnerCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style
        x:Key="PanelGhostButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Margin" Value="2,6,2,0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="PanelSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="PanelSectionDividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,12" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
    </Style>

    <Style x:Key="PanelActionBarStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>

    <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style
        x:Key="FieldInputStyle"
        BasedOn="{StaticResource {x:Type TextBox}}"
        TargetType="TextBox">
        <Setter Property="ui:TextBoxHelper.IsEnabled" Value="False" />
        <Setter Property="converters:NumericInputBehavior.IsEnabled" Value="True" />
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="Height" Value="30" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="PanelApplyButtonStyle"
        BasedOn="{StaticResource PixSnapAccentButtonStyle}"
        TargetType="Button">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="15,2" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style
        x:Key="PanelCancelButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="15,2" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="AnnotationToolbarButtonStyle"
        BasedOn="{StaticResource ToolbarIconButtonStyle}"
        TargetType="Button">
        <Setter Property="Margin" Value="0,0,2,0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="AnnotationPanelToolButtonStyle"
        BasedOn="{StaticResource AnnotationToolbarButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="2" />
    </Style>

    <Style
        x:Key="ColorSwatchButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style
        x:Key="ColorPresetButtonStyle"
        BasedOn="{StaticResource ColorSwatchButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PanelToggleButtonStyle"
        BasedOn="{StaticResource PixSnapToggleButtonStyle}"
        TargetType="ToggleButton">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="13" />
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="CustomAnnotationColorButtonStyle"
        BasedOn="{StaticResource ColorPresetButtonStyle}"
        TargetType="Button">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCustomAnnotationColorSelected}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PanelIconButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="PanelCompactFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

</ResourceDictionary>
