<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <!--  Win11 设置类页面通用样式  -->
    <Style x:Key="SettingsPageRootStyle" TargetType="Grid">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="SettingsGroupCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="SettingsCardSeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="60,0,16,0" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
    </Style>

    <Style x:Key="SettingsCardRowStyle" TargetType="Border">
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <Style
        x:Key="SettingsPathTextBoxStyle"
        BasedOn="{StaticResource {x:Type TextBox}}"
        TargetType="TextBox">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  紧凑开关：不显示 On/Off 文字  -->
    <Style x:Key="SettingsToggleSwitchStyle" TargetType="ui:ToggleSwitch">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="OnContent" Value="{x:Null}" />
        <Setter Property="OffContent" Value="{x:Null}" />
    </Style>

    <Style
        x:Key="SettingsActionButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style
        x:Key="SettingsIconButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style x:Key="SettingsSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="Padding" Value="4,8,4,8" />
    </Style>

    <Style x:Key="SettingsSectionTitleInCardStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="12,4,12,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsFieldRowStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style x:Key="SettingsFieldSeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="12,0" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
    </Style>

    <Style
        x:Key="SettingsComboBoxStyle"
        BasedOn="{StaticResource {x:Type ComboBox}}"
        TargetType="ComboBox">
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="MaxWidth" Value="200" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="SettingsSectionHeaderStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,10" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="AboutShortcutKeyStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SettingsRowIconStyle" TargetType="ui:FontIcon">
        <Setter Property="Width" Value="20" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
    </Style>

    <Style x:Key="SettingsRowTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsRowDescStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="SettingsPageHeaderIconHostStyle" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="SettingsPageHeaderTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsPageHeaderSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="FlyoutMenuCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="4" />
        <Setter Property="MinWidth" Value="200" />
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="16"
                    Direction="270"
                    Opacity="0.18"
                    ShadowDepth="4"
                    Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  兼容 SettingsWindow 原有 Style Key  -->
    <Style
        x:Key="GroupCardStyle"
        BasedOn="{StaticResource SettingsGroupCardStyle}"
        TargetType="Border" />
    <Style
        x:Key="CardSeparatorStyle"
        BasedOn="{StaticResource SettingsCardSeparatorStyle}"
        TargetType="Border" />
    <Style
        x:Key="CardRowStyle"
        BasedOn="{StaticResource SettingsCardRowStyle}"
        TargetType="Border" />
    <Style
        x:Key="SectionHeaderStyle"
        BasedOn="{StaticResource SettingsSectionHeaderStyle}"
        TargetType="TextBlock" />
    <Style
        x:Key="RowIconStyle"
        BasedOn="{StaticResource SettingsRowIconStyle}"
        TargetType="ui:FontIcon" />
    <Style
        x:Key="RowTitleStyle"
        BasedOn="{StaticResource SettingsRowTitleStyle}"
        TargetType="TextBlock" />
    <Style
        x:Key="RowDescStyle"
        BasedOn="{StaticResource SettingsRowDescStyle}"
        TargetType="TextBlock" />

</ResourceDictionary>
