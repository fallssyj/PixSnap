<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PixSnap.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <!--  标注工具条间距规范  -->
    <Thickness x:Key="EditDockGroupMargin">32,0,0,0</Thickness>
    <Thickness x:Key="EditDockHostPadding">22,16</Thickness>
    <Thickness x:Key="EditDockContextPadding">20,14</Thickness>
    <sys:Double x:Key="EditDockControlHeight">32</sys:Double>

    <DropShadowEffect
        x:Key="AnnotationDockShadowEffect"
        BlurRadius="32"
        Direction="270"
        Opacity="0.52"
        ShadowDepth="8"
        Color="#000000" />

    <Style x:Key="EditDockHostStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource EditDockHostPadding}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Effect" Value="{StaticResource AnnotationDockShadowEffect}" />
        <Setter Property="Opacity" Value="0.98" />
    </Style>

    <Style x:Key="EditDockToolPillStyle" TargetType="Border">
        <Setter Property="Margin" Value="12,0,0,0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="EditDockToolPillTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditDockRowDividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,16" />
        <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <Style x:Key="EditDockSeparatorStyle" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="Margin" Value="20,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style x:Key="EditDockToolPanelStripStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <sys:Double x:Key="EditDockPropertyFieldWidth">200</sys:Double>

    <Style TargetType="controls:DockSliderField">
        <Setter Property="FieldWidth" Value="{StaticResource EditDockPropertyFieldWidth}" />
    </Style>

    <Style x:Key="EditDockToolPanelHostStyle" BasedOn="{StaticResource EditDockHostStyle}" TargetType="Border">
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="MinWidth" Value="660" />
    </Style>

    <Style x:Key="EditDockPropertyStripStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="20,0,0,0" />
    </Style>

    <Style x:Key="EditDockPropertyLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Opacity" Value="0.88" />
    </Style>

    <Style x:Key="EditDockPropertyValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="EditDockSliderValueTextStyle" BasedOn="{StaticResource FieldInputStyle}" TargetType="TextBox">
        <Setter Property="MinWidth" Value="16" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CaretBrush" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
                <Setter Property="Padding" Value="4,0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditDockSliderRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Rectangle Fill="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditDockSliderDecreaseRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border
                        Height="3"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SystemControlForegroundAccentBrush}"
                        CornerRadius="1.5" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditDockSliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid
                        x:Name="ThumbRoot"
                        Width="12"
                        Height="20"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Ellipse
                            Width="10"
                            Height="10"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource SystemControlForegroundAccentBrush}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbRoot" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.15" ScaleY="1.15" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbRoot" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.15" ScaleY="1.15" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="EditDockSliderTemplate" TargetType="Slider">
        <Grid MinHeight="20" VerticalAlignment="Center">
            <Border
                Height="3"
                VerticalAlignment="Center"
                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                CornerRadius="1.5"
                Opacity="0.42"
                SnapsToDevicePixels="True" />
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource EditDockSliderDecreaseRepeatButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource EditDockSliderRepeatButtonStyle}" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource EditDockSliderThumbStyle}" />
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style x:Key="EditDockSliderStyle" TargetType="Slider">
        <Setter Property="Height" Value="20" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource EditDockSliderTemplate}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="EditDockPropertyRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditDockPropertyFieldSpacingStyle" TargetType="FrameworkElement">
        <Setter Property="Margin" Value="0,0,32,0" />
    </Style>

    <Style x:Key="EditDockContextBarStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,16,0,0" />
        <Setter Property="Padding" Value="{StaticResource EditDockContextPadding}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="EditDockActionsStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditDockContextRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="EditDockContextGroupStyle"
        BasedOn="{StaticResource EditDockContextRowStyle}"
        TargetType="StackPanel">
        <Setter Property="Margin" Value="{StaticResource EditDockGroupMargin}" />
    </Style>

    <Style x:Key="EditDockContextLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="EditDockIconButtonSpacedStyle" BasedOn="{StaticResource PanelIconButtonStyle}" TargetType="Button">
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style x:Key="EditDockChipButtonStyle" BasedOn="{StaticResource PanelCancelButtonStyle}" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="False" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MinHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

    <!--  工具条统一高度：Toggle / 输入框 / 下拉  -->
    <Style x:Key="EditDockBarToggleStyle" BasedOn="{StaticResource PixSnapToggleButtonStyle}" TargetType="ToggleButton">
        <Setter Property="Height" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MinHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MaxHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="EditDockBoldToggleStyle"
        BasedOn="{StaticResource EditDockBarToggleStyle}"
        TargetType="ToggleButton">
        <Setter Property="Width" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MinWidth" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="20,0,0,0" />
    </Style>

    <Style
        x:Key="EditDockTextToggleStyle"
        BasedOn="{StaticResource EditDockBarToggleStyle}"
        TargetType="ToggleButton">
        <Setter Property="MinWidth" Value="56" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style
        x:Key="EditDockPropertyChipToggleStyle"
        BasedOn="{StaticResource EditDockBarToggleStyle}"
        TargetType="ToggleButton">
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="EditDockFontComboStyle" BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultComboBoxStyleKey}}" TargetType="ComboBox">
        <Setter Property="Width" Value="176" />
        <Setter Property="MinWidth" Value="148" />
        <Setter Property="Height" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MinHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MaxHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditDockFontSizeFieldStyle" BasedOn="{StaticResource FieldInputStyle}" TargetType="TextBox">
        <Setter Property="Width" Value="56" />
        <Setter Property="MinWidth" Value="56" />
        <Setter Property="Height" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MinHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MaxHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditDockInlineNumberBoxStyle" BasedOn="{StaticResource FieldInputStyle}" TargetType="TextBox">
        <Setter Property="Width" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="EditDockCompactFieldStyle" BasedOn="{StaticResource FieldInputStyle}" TargetType="TextBox">
        <Setter Property="MinWidth" Value="56" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MinHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="MaxHeight" Value="{StaticResource EditDockControlHeight}" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
