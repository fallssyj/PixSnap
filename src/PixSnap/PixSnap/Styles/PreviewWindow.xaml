<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style
        x:Key="PreviewPrimaryActionButtonStyle"
        BasedOn="{StaticResource OpenFileButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="80" />
        <Setter Property="Height" Value="35" />
        <Setter Property="Margin" Value="10,5,0,5" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="10"
                    Direction="315"
                    Opacity="0.3"
                    ShadowDepth="5"
                    Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PreviewToolbarSeparatorStyle" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Margin" Value="6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
    </Style>

    <Style x:Key="PreviewTitleChipStyle" TargetType="Border">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="30,0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppGradientEndBrush}" />
        <Setter Property="BorderThickness" Value="0.8" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="10"
                    Direction="315"
                    Opacity="0.3"
                    ShadowDepth="5"
                    Color="Black" />
            </Setter.Value>
        </Setter>
        <Setter Property="Visibility" Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding CaptureTitleDisplay.Length}" Value="0">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PreviewTitleTextStyle" TargetType="TextBlock">
        <Setter Property="MaxWidth" Value="420" />
        <Setter Property="Margin" Value="5,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="PreviewWindowStateButtonStyle"
        BasedOn="{StaticResource IconButton}"
        TargetType="Button">
        <Setter Property="ToolTip" Value="最大化" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                <Setter Property="ToolTip" Value="还原" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PreviewWindowStateGlyphStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SegoeFluent}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Text" Value="{StaticResource Glyph_Maximize}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMaximized}" Value="True">
                <Setter Property="Text" Value="{StaticResource Glyph_Restore}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="AnnotationToolbarButtonStyle"
        BasedOn="{StaticResource RibbonToolButtonStyle}"
        TargetType="Button">
        <Setter Property="Margin" Value="0,0,2,0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
