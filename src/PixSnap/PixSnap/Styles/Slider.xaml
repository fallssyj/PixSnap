<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="Slider">
        <Setter Property="Width" Value="300" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="{DynamicResource PreviewZoomTrackInactiveBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SliderActiveTrackBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Margin="6,0">
                        <Border
                            Height="8"
                            VerticalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Opacity="0.92" />
                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="{TemplateBinding Foreground}" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border
                                                Height="8"
                                                VerticalAlignment="Center"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4,0,0,4" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb
                                    Width="34"
                                    Height="34"
                                    Margin="-10,0"
                                    Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid>
                                                <Ellipse
                                                    Width="34"
                                                    Height="34"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Fill="#443C4048">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="8"
                                                            ShadowDepth="0"
                                                            Color="#5532363D" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <Ellipse
                                                    Width="15"
                                                    Height="15"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Fill="{DynamicResource SliderActiveTrackBrush}" />
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Background="Transparent" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>