<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <!--  Fluent 字体栈：拉丁优先 Segoe UI Variable，中文优先 Microsoft YaHei UI（比 YaHei 更细、更现代）  -->
    <FontFamily x:Key="AppFontFamily">Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI, Microsoft YaHei, sans-serif</FontFamily>
    <FontFamily x:Key="AppFontFamilyDisplay">Segoe UI Variable Display, Segoe UI Semibold, Microsoft YaHei UI, Microsoft YaHei, sans-serif</FontFamily>
    <FontFamily x:Key="AppFontFamilyMono">Cascadia Mono, Cascadia Code, Consolas, Microsoft YaHei UI, monospace</FontFamily>

    <!--  字号阶梯（Fluent type ramp）  -->
    <sys:Double x:Key="AppFontSizeCaption" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="AppFontSizeBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="AppFontSizeBodyStrong" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="AppFontSizeSubtitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="AppFontSizeTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">28</sys:Double>
    <sys:Double x:Key="AppFontSizeStatus" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>

    <!--  全局 TextBlock 基类  -->
    <Style x:Key="AppTextBlockBaseStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="CaptionTextStyle" BasedOn="{StaticResource AppTextBlockBaseStyle}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="BodyStrongTextStyle" BasedOn="{StaticResource AppTextBlockBaseStyle}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBodyStrong}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubtitleTextStyle" BasedOn="{StaticResource AppTextBlockBaseStyle}" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyDisplay}" />
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeSubtitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="TitleTextStyle" BasedOn="{StaticResource AppTextBlockBaseStyle}" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyDisplay}" />
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!--  AI / 文件处理进度提示  -->
    <Style x:Key="ProcessingStatusCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="MinWidth" Value="300" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ProcessingStatusTextStyle" BasedOn="{StaticResource AppTextBlockBaseStyle}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeStatus}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style
        x:Key="ProcessingStatusProgressBarStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultProgressBarStyleKey}}"
        TargetType="ProgressBar">
        <Setter Property="Height" Value="4" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
    </Style>

</ResourceDictionary>
