<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorAppBackground">#FF0F172A</Color>
    <Color x:Key="ColorSurface">#FF111827</Color>
    <Color x:Key="ColorSurfaceAlt">#FF1F2937</Color>
    <Color x:Key="ColorBorder">#FF334155</Color>
    <Color x:Key="ColorTextPrimary">#FFE5E7EB</Color>
    <Color x:Key="ColorTextSecondary">#FF9CA3AF</Color>
    <Color x:Key="ColorButtonPrimary">#FF0EA5A4</Color>
    <Color x:Key="ColorButtonForeground">#FF082F33</Color>
    <Color x:Key="ColorButtonBorder">#FF164E63</Color>
    <Color x:Key="ColorFocus">#FF38BDF8</Color>
    <Color x:Key="ColorDisabledBackground">#FF374151</Color>
    <Color x:Key="ColorDisabledForeground">#FF6B7280</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorAppBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource ColorSurfaceAlt}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="ButtonPrimaryBackgroundBrush" Color="{StaticResource ColorButtonPrimary}" />
    <SolidColorBrush x:Key="ButtonPrimaryForegroundBrush" Color="{StaticResource ColorButtonForeground}" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ColorButtonBorder}" />
    <SolidColorBrush x:Key="FocusBrush" Color="{StaticResource ColorFocus}" />
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="{StaticResource ColorDisabledBackground}" />
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="{StaticResource ColorDisabledForeground}" />
</ResourceDictionary>
