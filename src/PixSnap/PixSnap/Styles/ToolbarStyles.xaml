<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <!--  iNKORE 按钮基类：统一手型光标  -->
    <Style
        x:Key="PixSnapButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultButtonStyleKey}}"
        TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
    </Style>

    <Style
        x:Key="PixSnapAccentButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"
        TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
    </Style>

    <Style
        x:Key="PixSnapToggleButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultToggleButtonStyleKey}}"
        TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
    </Style>

    <!--  Win11 标题栏/工具栏：默认无边框，悬停时才显示底色  -->
    <ControlTemplate x:Key="BorderlessToolbarButtonTemplate" TargetType="Button">
        <Border
            x:Name="Root"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="4"
            SnapsToDevicePixels="True">
            <ContentPresenter
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                RecognizesAccessKey="True" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Background" Value="Transparent" />
                <Setter Property="Opacity" Value="0.4" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="False" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Root" Property="Background" Value="Transparent" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="False" />
                    <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Root" Property="Background" Value="Transparent" />
            </MultiTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="BorderlessToolbarButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource BorderlessToolbarButtonTemplate}" />
    </Style>

    <ControlTemplate x:Key="BorderlessToolbarToggleButtonTemplate" TargetType="ToggleButton">
        <Border
            x:Name="Root"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="4"
            SnapsToDevicePixels="True">
            <ContentPresenter
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                RecognizesAccessKey="True" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Background" Value="Transparent" />
                <Setter Property="Opacity" Value="0.4" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="False" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Root" Property="Background" Value="Transparent" />
            </MultiTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="BorderlessToolbarToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource BorderlessToolbarToggleButtonTemplate}" />
    </Style>

    <!--  右键/弹出菜单项：全宽、左对齐、无按钮边框  -->
    <Style
        x:Key="ContextMenuItemButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  标题栏编辑模式按钮：当前模式高亮（各模式独立 Style，绑定 Is*Mode）  -->
    <Style
        x:Key="PreviewCropModeButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCropMode}" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PreviewRoundCornerModeButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRoundCornerMode}" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PreviewEraserModeButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEraserMode}" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PreviewAnnotateModeButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAnnotateMode}" Value="True">
                <Setter Property="Background" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarSeparatorStyle" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style
        x:Key="BorderlessPinToggleButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarToggleButtonStyle}"
        TargetType="ToggleButton">
        <Setter Property="ToolTip" Value="置顶" />
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="ToolTip" Value="取消置顶" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OverlayChipButtonStyle" TargetType="Button">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="52" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource BorderlessToolbarButtonTemplate}" />
    </Style>

    <!--  Flyout 弹出菜单：托盘 / AI 右键等共用  -->
    <Style x:Key="FlyoutMenuIconStyle" TargetType="ui:FontIcon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style
        x:Key="FlyoutMenuIconAccentStyle"
        BasedOn="{StaticResource FlyoutMenuIconStyle}"
        TargetType="ui:FontIcon">
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
    </Style>

    <Style x:Key="FlyoutMenuTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style
        x:Key="FlyoutMenuButtonStyle"
        BasedOn="{StaticResource ContextMenuItemButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="FlyoutMenuSeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="8,4" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
    </Style>

</ResourceDictionary>
