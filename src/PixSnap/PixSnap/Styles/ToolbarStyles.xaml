<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern">

    <!--  iNKORE 按钮基类：统一手型光标  -->
    <Style
        x:Key="PixSnapButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultButtonStyleKey}}"
        TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style
        x:Key="PixSnapAccentButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"
        TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style
        x:Key="PixSnapToggleButtonStyle"
        BasedOn="{StaticResource {x:Static ui:ThemeKeys.DefaultToggleButtonStyleKey}}"
        TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!--  Win11 标题栏/工具栏：默认无边框，悬停时才显示底色  -->
    <Style
        x:Key="BorderlessToolbarButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="BorderlessToolbarToggleButtonStyle"
        BasedOn="{StaticResource PixSnapToggleButtonStyle}"
        TargetType="ToggleButton">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  右键/弹出菜单项：全宽、左对齐、无按钮边框  -->
    <Style
        x:Key="ContextMenuItemButtonStyle"
        BasedOn="{StaticResource PixSnapButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ToolbarSeparatorStyle" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style
        x:Key="BorderlessPinToggleButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarToggleButtonStyle}"
        TargetType="ToggleButton">
        <Setter Property="ToolTip" Value="置顶" />
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="ToolTip" Value="取消置顶" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="OverlayChipButtonStyle"
        BasedOn="{StaticResource BorderlessToolbarButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <!--  Flyout 弹出菜单：托盘 / AI 右键等共用  -->
    <Style x:Key="FlyoutMenuIconStyle" TargetType="ui:FontIcon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style
        x:Key="FlyoutMenuIconAccentStyle"
        BasedOn="{StaticResource FlyoutMenuIconStyle}"
        TargetType="ui:FontIcon">
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
    </Style>

    <Style x:Key="FlyoutMenuTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style
        x:Key="FlyoutMenuButtonStyle"
        BasedOn="{StaticResource ContextMenuItemButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="FlyoutMenuSeparatorStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="8,4" />
        <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
    </Style>

    <!--  兼容旧 Key  -->
    <Style x:Key="TrayMenuIconStyle" BasedOn="{StaticResource FlyoutMenuIconStyle}" TargetType="ui:FontIcon" />
    <Style x:Key="TrayMenuTextStyle" BasedOn="{StaticResource FlyoutMenuTextStyle}" TargetType="TextBlock" />
    <Style x:Key="TrayFlyoutMenuButtonStyle" BasedOn="{StaticResource FlyoutMenuButtonStyle}" TargetType="Button" />
    <Style x:Key="TrayFlyoutSeparatorStyle" BasedOn="{StaticResource FlyoutMenuSeparatorStyle}" TargetType="Border" />

</ResourceDictionary>
