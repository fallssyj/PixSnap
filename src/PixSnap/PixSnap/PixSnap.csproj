<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <AssemblyName>PixSnap</AssemblyName>
    <RootNamespace>PixSnap</RootNamespace>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <ApplicationIcon>Assets\icons\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\fonts\MiSans-Normal.ttf" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\icons\app.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NativeScreenCapturer\NativeScreenCapturer.vcxproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\fonts\MiSans-Normal.ttf" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Styles\Theme\" />
  </ItemGroup>

</Project>